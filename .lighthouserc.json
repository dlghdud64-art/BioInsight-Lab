{
  "//": "§11.246e-cont #lighthouse-ci-automation — 호영님 §11.246e baseline 자연 후속.",
  "//strategy": "§11.246e (PageSpeed Insights API 일회성 측정) → continuous CI 자동화. PR 마다 Core Web Vitals 회귀 차단.",
  "//public-urls-only": "auth 필요 dashboard 제외. /, /pricing, /login 만 측정. labaxis.co.kr production 정합.",
  "ci": {
    "collect": {
      "url": [
        "https://labaxis.co.kr",
        "https://labaxis.co.kr/pricing",
        "https://labaxis.co.kr/login"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "//warn-vs-error": "§11.246e-cont-2 — 핵심 Core Web Vitals (LCP/CLS/INP) 만 error 강화. 나머지 categories scores + 2차 metric (TBT/SI/interactive/FID/max-potential-fid) 은 warn 유지. 호영님 결정 'baseline 안정화 후 핵심 metric 만' 정합.",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "interaction-to-next-paint": ["error", { "maxNumericValue": 200 }],
        "max-potential-fid": ["warn", { "maxNumericValue": 200 }],
        "interactive": ["warn", { "maxNumericValue": 5000 }],
        "speed-index": ["warn", { "maxNumericValue": 3500 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
