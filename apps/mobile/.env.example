# ============================================================
# LabAxis (mobile · Expo) — 환경변수 체크리스트 (변수 이름만 · 값 없음)
# ------------------------------------------------------------
#  · 로컬: 이 파일을 apps/mobile/.env.local 로 복사 후 실제 값 입력.
#          (.env* 은 .gitignore 로 커밋 차단 — 실제 값 절대 커밋 금지)
#  · EXPO_PUBLIC_* 은 클라이언트 번들에 주입되는 공개 값 → 시크릿 넣지 말 것.
#  · EAS 빌드/배포 시에는 EAS 프로젝트 시크릿(eas secret) 또는 eas.json env 로 주입.
# ============================================================

# API 서버 베이스 URL (필수)
EXPO_PUBLIC_API_URL=

# Google OAuth 클라이언트 ID (모바일 로그인)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Expo 프로젝트 ID (푸시 알림)
EXPO_PUBLIC_PROJECT_ID=

# Sentry DSN (선택 — 크래시 리포팅)
EXPO_PUBLIC_SENTRY_DSN=
