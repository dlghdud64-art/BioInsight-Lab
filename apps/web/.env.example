# ============================================================
# BioInsight Lab — 필수 환경변수 체크리스트
# 이 파일을 .env.local 또는 배포 환경 변수로 복사하여 설정하세요.
# ============================================================

# ----- 데이터베이스 (필수) -----
DATABASE_URL="postgresql://user:password@host:5432/bioinsight"
DIRECT_URL="postgresql://user:password@host:5432/bioinsight"

# ----- 인증 (필수) -----
AUTH_SECRET="<랜덤 32자 이상 시크릿 — openssl rand -base64 32>"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ----- 모바일 API (필수) -----
# JWT 시크릿 (미설정 시 서버 시작 실패)
MOBILE_JWT_SECRET="<랜덤 32자 이상 시크릿>"

# 개발 환경 전용 임시 비밀번호 (프로덕션에서는 반드시 제거)
# MOBILE_DEV_PASSWORD="<개발환경에서만 설정>"

# ----- Stripe 결제 (선택 — 미설정 시 결제 기능 비활성화) -----
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PRICE_ID_TEAM_MONTHLY=""
# STRIPE_WEBHOOK_SECRET=""

# ----- AI 라벨 스캔 (선택 — 미설정 시 이미지 OCR 비활성화, 텍스트 입력만 동작) -----
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
# GOOGLE_GEMINI_API_KEY=""

# ----- 외부 서비스 (선택) -----
# SENDGRID_API_KEY=""
# SENDGRID_INBOUND_SECRET=""
# SENTRY_DSN=""
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
