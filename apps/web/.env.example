# ============================================================
# LabAxis (web) — 환경변수 체크리스트 (변수 이름만 · 값 없음)
# ------------------------------------------------------------
# 사용법
#  · 로컬 개발: 이 파일을 apps/web/.env.local 로 복사 후 실제 값 입력.
#              (.env / .env.local 은 .gitignore 로 커밋 차단 — 실제 값 절대 커밋 금지)
#  · 배포(Vercel): 값을 커밋하지 말 것. Vercel 프로젝트 →
#              Settings → Environment Variables 에 아래 이름으로 등록.
#              (Production / Preview / Development 스코프 구분 등록)
#              NEXT_PUBLIC_* 은 빌드타임 주입이므로 Vercel 에도 반드시 등록.
# ============================================================

# ----- 데이터베이스 (필수) -----
DATABASE_URL=
DIRECT_URL=

# ----- 인증 / NextAuth (필수) -----
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Supabase (필수 — DB 호스팅 + Storage) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
SUPABASE_SDS_BUCKET=
SUPABASE_REPLY_BUCKET=

# ----- 앱 URL / 도메인 -----
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_DOMAIN=

# ----- 이메일 발송 -----
# Resend (현행)
RESEND_API_KEY=
EMAIL_FROM=
ENROLLMENT_NOTIFY_EMAIL=
# SendGrid (레거시 · 인바운드 회신 파서)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_INBOUND_SECRET=

# ----- AI / 라벨 OCR (선택 — 미설정 시 룰기반 폴백) -----
AI_PROVIDER=
LABAXIS_AI_PROVIDER=
AI_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
GOOGLE_VISION_API_KEY=
GEMINI_MODEL=
GEMINI_FALLBACK_MODEL=
# AI 런타임 튜닝 플래그
AI_RUNTIME_ENABLED=
AI_ROLLOUT_PERCENT=
AI_MIN_CONFIDENCE=
AI_MAX_RETRIES=
AI_TIMEOUT_MS=
AI_DAILY_COST_LIMIT_USD=
AI_FALLBACK_TO_RULES=
AI_SHADOW_MODE=
AI_ASYNC_SHADOW=
AI_CANARY_CONFIG=
# 파이프라인 런타임 스위치
ENABLE_INGESTION_RUNTIME=
ENABLE_EXTRACTION_RUNTIME=
ENABLE_CLASSIFICATION_RUNTIME=
ENABLE_ENTITY_LINKING_RUNTIME=
ENABLE_VERIFICATION_RUNTIME=
ENABLE_WORK_QUEUE_RUNTIME=
# 운영 브리핑 LLM
OPERATIONAL_BRIEF_USE_LLM=
OPERATIONAL_BRIEF_KV_URL=

# ----- 결제 / Stripe (선택 — 미설정 시 결제 비활성화) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_TEAM_MONTHLY=
STRIPE_PRICE_ID_BUSINESS_MONTHLY=
PRICING_ENFORCE_CUTOFF=

# ----- 보안 / CSRF / Cron -----
LABAXIS_CSRF_MODE=
LABAXIS_CSRF_SECRET=
LABAXIS_TRUSTED_ORIGINS=
CRON_SECRET=

# ----- 외부 서비스 API (선택) -----
EXCHANGE_RATE_API_KEY=
DATA_GO_KR_SERVICE_KEY=
PROCUREMENT_API_KEY=

# ----- 스토리지 / 영속성 프로바이더 -----
STORAGE_PROVIDER=
PERSISTENCE_PROVIDER=
CATALOG_PUBLIC_INGEST=

# ----- 모바일 API 브리지 (웹 서버측) -----
# JWT 시크릿 (미설정 시 모바일 인증 서버 시작 실패)
MOBILE_JWT_SECRET=
# 개발 환경 전용 임시 비밀번호 — 프로덕션에서는 반드시 미설정
MOBILE_DEV_PASSWORD=

# ----- 기능 플래그 (선택) -----
NEXT_PUBLIC_FEATURE_BARCODE_SCAN_MOCK=
NEXT_PUBLIC_FF_PURCHASING=
NEXT_PUBLIC_FF_CONTRACT_SHELL=
NEXT_PUBLIC_FF_CONTRACT_DASHBOARD=
NEXT_PUBLIC_FF_TODAY_HUB_STRIP=

# ----- 기타 동작 모드 (선택) -----
PDF_MODE=
DEMO_MODE=
DISABLE_AUTO_VERIFY=
INBOUND_RFQ_ENABLED=

# ----- E2E 테스트 (로컬/CI 전용 · 선택) -----
E2E_BASE_URL=
E2E_SESSION_TOKEN=
E2E_ADMIN_SESSION_TOKEN=

# 참고: NODE_ENV / CI / VERCEL_URL 은 플랫폼이 자동 주입 — 직접 설정 불필요.
