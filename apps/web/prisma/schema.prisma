  createdAt       DateTime         @default(now())

  inventory ProductInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([userId])
  @@index([organizationId])
}

