// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL") — removed 2026-04-25 (ADR-002 §11.13).
  // Build-time prisma migrate deploy is permanently retired; migrations
  // are now operator-shell only. See DEV_RUNBOOK §9.
}

// ?용???권한
enum UserRole {
  RESEARCHER // ?구??
  BUYER // 구매 ?당??
  SUPPLIER // 공급??
  ADMIN // 관리자
}

// 조직 ???? (?크?페?스 ??)
enum OrganizationRole {
  VIEWER // 조회?가??
  REQUESTER // 견적 ?청 가??
  APPROVER // 견적 ?인 가??
  ADMIN // 조직 관리자
  OWNER // 최고 관리자 (조직 생성자, 1인 제한)
}

// 구독 ?랜 ???
// 팀 역할
enum TeamRole {
  ADMIN   // 팀 관리자
  MEMBER  // 일반 멤버
  VIEWER  // 조회만 가능
}

// 구매 요청 상태
enum PurchaseRequestStatus {
  PENDING   // 대기 중
  APPROVED  // 승인됨
  REJECTED  // 거절됨
  CANCELLED // 취소됨
}

enum SubscriptionPlan {
  FREE // 무료/Beta
  TEAM // ? ?랜
  ORGANIZATION // 조직/Enterprise ?랜
}

// 조직/?크?페?스
model Organization {
  id                String           @id @default(cuid())
  name              String
  description       String?          @db.Text
  organizationType  String?          // R&D 연구소, QC/QA 품질관리, 시험·검사 기관, 대학 연구실, 기타
  plan              SubscriptionPlan @default(FREE) // 구독 ?랜
  planExpiresAt     DateTime? // ?랜 만료??
  maxMembers        Int? // 최? 멤버 ??(?랜??한)
  maxQuotesPerMonth Int? // ?별 최? ?목 리스????
  maxSharedLinks    Int? // 최대 공유 링크 수
  logoUrl           String?          // 조직 로고 이미지 URL
  slug              String?          @unique // 조직 고유 주소 (예: my-lab)
  timezone          String           @default("Asia/Seoul") // IANA timezone — 예산 기간 기준
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // 관?
  members      OrganizationMember[]
  quotes       Quote[]
  templates    QuoteTemplate[]
  inventories  ProductInventory[]
  subscription Subscription? // 구독 ?보
  activityLogs  ActivityLog[]
  auditLogs     AuditLog[]
  dataAuditLogs DataAuditLog[]
  orders        Order[]
  userBudgets   UserBudget[]
  invites       OrganizationInvite[]
  budgets       Budget[]
  teams         Team[]
  billingInfo   BillingInfo?
  aiActionItems    AiActionItem[]
  ingestionEntries IngestionEntry[]
  spendingCategories SpendingCategory[]
  categoryBudgets    CategoryBudget[]
  budgetEvents       BudgetEvent[]
  // #user-supplier-registration — 조직 단위 supplier-book (한국 연구실
  // 단위 거래처 명단 정합).
  organizationVendors OrganizationVendor[]
  // #vendor-catalog-product-matching Phase 1 — 조직 단위 vendor-product carry.
  organizationVendorProducts OrganizationVendorProduct[]
  // Organization ↔ Workspace 1:1 bootstrap (옵션 B - organization-workspace-bootstrap.md 참조)
  // Phase 2 (2026-04-17): Workspace.organizationId 는 NOT NULL 로 승격됐지만, 반대 방향인 이 필드는
  // optional 유지. 이유: Organization 테이블에는 Workspace 를 가리키는 FK 가 없으므로 DB 레벨에서
  // "모든 Organization 에 Workspace 존재" 를 강제할 수 없고 (Prisma validator 가 차단), 1:1 은
  // createOrganization 트랜잭션이 애플리케이션 레이어에서 보장한다.
  workspace          Workspace?
  // §11.348-A — 조직 스코프 검증 대기 입고안.
  receivingDrafts    ReceivingDraft[]
  // §11.348-B-1 — 조직 스코프 SDS 문서.
  sdsDocuments       SDSDocument[]

  @@index([name])
  @@index([plan])
}

// 조직 멤버
model OrganizationMember {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationRole @default(VIEWER)
  // §11.193d Phase 2 — workflow capabilities (운영 tag, RBAC role 과 별도 layer).
  //   호영님 prototype 시안 — "1인 동시 Lab Manager + Approver + Requester 보유".
  //   값은 lib/permissions/workflow-capabilities.ts 의 WORKFLOW_CAPABILITIES
  //   whitelist (LAB_MANAGER / APPROVER / REQUESTER). getWorkflowCapabilities()
  //   가 array/null/object/string 모든 input 안전 처리.
  workflowCapabilities Json @default("[]")
  /// #approver-routing-per-user-limit-organization-member — 단일 건 결재
  /// 한도 (KRW). null = 무제한 (default). amount > approvalLimit 시
  /// selectApproverByAmount 가 다음 fallback (org_owner → org_admin →
  /// workspace_admin chain). 직전 WorkspaceMember.approvalLimit (Phase 1)
  /// 와 동일 패턴.
  approvalLimit Int?
  /// #approver-routing-multi-owner-roundrobin — 마지막 결재 할당 timestamp
  /// (organization member 측). org_owner / org_admin candidate 분산 lock.
  lastApprovalAssignedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // 관?
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(RESEARCHER)
  organization  String? // ?거???드 (조직?직접 ?력)
  phone         String?   // §11.69 운영자 연락처 (settings page 에서 update)
  // §11.97 #user-approval-policy-schema-add — 운영 정책 (read-only, admin 변경).
  // settings 페이지의 "운영 정책 미설정" 3 항목 backing source.
  approvalLimit    BigInt? // 단일 건 승인 한도 (KRW). null = 정책 미설정.
  costCenter       String? // 기본 Cost Center 코드 (예: "RND-BIO-SITE01")
  defaultLocation  String? // 기본 입고 위치 (예: "제1R&D센터 중앙창고")
  // §11.230c (a) #user-preferences-server-persist — generic preferences JSON.
  //   shape: { columnPrefs: { quotes: { widths, visibility, order } } }.
  //   후속 cluster 통합 가능 (briefing collapse 등). zod 가드 client/server.
  preferences      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // §11.133 #admin-user-soft-delete — soft delete marker. null=active,
  // truthy=반려/삭제. getUsers filter + auth.ts OAuth 차단 동시 적용.
  deletedAt     DateTime?

  // NextAuth 관?
  accounts Account[]
  sessions Session[]

  // 관?
  quotes              Quote[]
  comparisons         Comparison[]
  favorites           Favorite[]
  searchHistory       SearchHistory[]
  organizationMembers OrganizationMember[]
  workspaceMembers    WorkspaceMember[] // Workspace membership
  reviews             Review[]
  templates           QuoteTemplate[]
  inventories         ProductInventory[]
  inventoryUsage      InventoryUsage[]
  inventoryRestocks   InventoryRestock[]
  inspections         Inspection[]
  // #user-supplier-registration — 누가 등록한 organization vendor (audit).
  createdOrganizationVendors OrganizationVendor[]
  // #vendor-catalog-product-matching Phase 1 — 누가 매핑한 vendor-product (audit).
  createdOrganizationVendorProducts OrganizationVendorProduct[]
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  dataAuditLogs       DataAuditLog[]
  orders              Order[]
  userBudgets         UserBudget[]
  // §11.101 — UserInventory model dropped (#inventory-model-consolidation
  // Phase 4 closeout). Application code 는 §11.58 에서 ProductInventory 로
  // 모두 정렬 완료. relation 제거.
  cart                Cart?
  teamMembers         TeamMember[]
  purchaseRequests    PurchaseRequest[] @relation("RequestedPurchases") // 요청한 구매 요청
  approvedRequests    PurchaseRequest[] @relation("ApprovedPurchases") // 승인한 구매 요청 (approverId)
  aiActionItems       AiActionItem[]
  ingestionUploads    IngestionEntry[] @relation("IngestionUploader")
  // #mobile-push-notification Phase 1 server — 사용자별 등록된 푸시 토큰
  devices             Device[]
  // §11.348-A — 검증 대기 입고안 소유자(발주 주체/감사).
  receivingDrafts     ReceivingDraft[]

  @@index([email])
  @@index([role])
}

// NextAuth.js v5??한 모델
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ?품 카테고리
enum ProductCategory {
  REAGENT // ?약
  TOOL // 기구
  EQUIPMENT // ?비
  RAW_MATERIAL // 원료(원부자재)
}

// ?품
model Product {
  id                    String                       @id @default(cuid())
  name                  String
  nameEn                String? // ?문?
  description           String?                      @db.Text
  descriptionEn         String?                      @db.Text
  descriptionTranslated String?                      @db.Text // 번역???명 (GPT 번역)
  category              ProductCategory
  brand                 String?
  modelNumber           String?
  catalogNumber         String? // 카탈로그 번호 (Cat.No)
  lotNumber             String? // Lot 번호 (배치 번호) - 원료(원부자재) 포함
  specifications        Json? // ?펙 ?보 (JSON)
  datasheetUrl          String?
  imageUrl              String?
  embedding             Unsupported("vector(1536)")? // 벡터 ?베??(pgvector)
  // 그룹?어 친화???드
  grade                 String? // Grade (HPLC grade, GMP, EP/USP, cell culture tested ??
  // §11.341 — internalGrade/gradeSource 는 migration 선적용 후 재추가(§11.337-hotfix P0:
  //   schema 가 migration 보다 먼저 배포되어 검색 findMany 가 없는 컬럼 SELECT → 장애).
  //   순서: prisma migrate deploy(prod 컬럼 생성) → schema 재추가 → 배포. 아래 2줄 보류.
  // internalGrade         String?
  // gradeSource           String?
  specification         String? // 규격/?량 (?? 1mg, 500mL, 0.22um ??
  // §11.326 — 통 1개 함량(규격). 입고 수량과 분리. 있으면 specification보다 우선.
  packSize              Float?  // 통 1개의 함량 수치 (예: 100)
  packUnit              String? // 함량 단위 (예: CAPSULES, mL)
  regulatoryCompliance  String? // 규제/?전 규격 (USP, EP, JP ??

  // 안전·규제 정보 (P1)
  msdsUrl    String? // MSDS/SDS 문서 URL
  safetyNote String? @db.Text // 안전 취급 요약/주의사항

  // 안전 필드 구조화 (P2)
  hazardCodes      Json? // 위험 코드 배열 (예: ["H314", "H290"])
  pictograms       Json? // GHS 피크토그램 배열 (예: ["corrosive", "exclamation"])
  storageCondition String? @db.Text // 보관 조건 (예: "2~8°C 냉장 보관")
  ppe              Json? // 개인보호장비 배열 (예: ["gloves", "goggles"])

  // 원료(원부자재) 전용 필드 (P1)
  coaUrl              String? // COA (Certificate of Analysis) URL
  specSheetUrl        String? // Spec Sheet URL
  pharmacopoeia       String? // 규정/표준 (예: "USP", "EP", "JP", "KP")
  countryOfOrigin     String? // 원산지
  manufacturer        String? // 제조사
  expiryDate          DateTime? // 유효기간

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  // 관?
  vendors         ProductVendor[]
  comparisons     ComparisonProduct[]
  favorites       Favorite[]
  recommendations ProductRecommendation[] @relation("ProductRecommendations")
  recommendedFor  ProductRecommendation[] @relation("RecommendedProducts")
  searchHistory   SearchHistory[]
  // §11.348-B-1 — 제품별 SDS/MSDS 문서(파일 스토리지 메타).
  sdsDocuments    SDSDocument[]
  reviews         Review[]
  quoteListItems  QuoteListItem[]
  inventories     ProductInventory[]
  cartItems       CartItem[]
  // #vendor-catalog-product-matching Phase 1 — 조직 단위 vendor-product carry.
  organizationVendorLinks OrganizationVendorProduct[]

  @@index([category])
  @@index([brand])
  @@index([name])
}

// §catalog-A Phase 1 — 조달청 공공데이터 식별 계층 reference (PLAN_catalog-public-ingest §4).
//   canonical 아님(projection). db.product를 절대 직접 덮지 않음 — 승격은 별도 명시 경로.
//   §11.341 교훈: Product 모델 무변경(FK/relation 미부착, linkedProductId = plain 컬럼)
//   → migration deploy 순서 무관하게 기존 findMany 무영향.
model ProcurementCatalogRef {
  prdctIdNo        String   @id // 물품식별번호 (제조사+모델 고유, dedup 키)
  prdctClsfcNo     String? // 물품분류번호 (UNSPSC 기반 8자리)
  dtilPrdctClsfcNo String? // 세부물품분류번호 (10자리)
  mfrtNm           String? // 제조업체명
  prdctNm          String? // 품명
  dtilPrdctNm      String? // 세부품명
  engPrdctNm       String? // 영문품명
  modelNm          String? // 모델명
  source           String   @default("public_procurement") // provenance 고정
  linkedProductId  String? // 승격 hook — 실사용 시에만 db.product id 주석 (FK 아님)
  ingestedAt       DateTime @default(now())
  sourceUpdatedAt  String? // 원천 등록/변경일 (조달청 표기 그대로)

  @@index([prdctClsfcNo])
  @@index([mfrtNm])
  @@index([prdctNm])
  @@index([linkedProductId])
}

// #vendor-partnership-tier Phase 1 — 4단계 partnership tier enum.
//   호영님 한국 시약 시장 strategy 정합:
//   - DIRECT_PARTNER: 직접 파트너십 / MOU (글로벌 제조사 본사 직거래)
//   - VERIFIED: 검증된 거래 (국내 총판, 정기 거래)
//   - GENERAL: 일반 거래 (default)
//   - UNVERIFIED: 미검증 (신규, 검토 필요)
enum VendorPartnershipTier {
  DIRECT_PARTNER
  VERIFIED
  GENERAL
  UNVERIFIED
}

// 벤더/공급??
model Vendor {
  id                String    @id @default(cuid())
  name              String
  nameEn            String?
  email             String?
  phone             String?
  website           String?
  country           String?   @default("KR")
  currency          String?   @default("KRW")
  // #vendor-partnership-tier — 글로벌 baseline.
  //   OrganizationVendor.partnershipTier 가 null 이면 본 값 사용 (overlay).
  partnershipTier   VendorPartnershipTier @default(GENERAL)
  // ?익 모델 관???드
  isPremium         Boolean   @default(false) // ?리미엄 ?랜 ??
  premiumExpiresAt  DateTime? // ?리미엄 만료??
  leadPricePerQuote Float?    @default(0) // 리드??과금 (견적 ?청??
  totalLeads        Int       @default(0) //?리드 ??
  totalRevenue      Float     @default(0) //??익
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // 관?
  products        ProductVendor[]
  quoteResponses  QuoteResponse[]
  billingRecords  VendorBillingRecord[]
  // #post-approval-purchase-order-flow Phase 1.2 — vendor 별 발주 (option A)
  orders          Order[]
  // #user-supplier-registration — 조직 단위 supplier-book 의 platform Vendor 연결.
  organizationLinks OrganizationVendor[]
  // #vendor-catalog-product-matching Phase 1 — 조직 단위 vendor-product carry.
  organizationProductLinks OrganizationVendorProduct[]
  // §11.348-A — 발주 후 입고 회신을 보낸 공급사.
  receivingDrafts   ReceivingDraft[]

  @@index([name])
  @@index([isPremium])
}

// ?품-벤더 관?(가? ?고, ?기 ?보)
model ProductVendor {
  id                String   @id @default(cuid())
  productId         String
  vendorId          String
  price             Float?
  currency          String   @default("KRW")
  priceInKRW        Float? // KRW ?산 가?
  stockStatus       String? // ?고 ?태
  leadTime          Int? // ?기??(???위)
  minOrderQty       Int?
  url               String?
  // ?리미엄 ?출 관??
  isPremiumFeatured Boolean  @default(false) // ?리미엄 추천 ?역 ?출
  premiumPriority   Int      @default(0) // ?리미엄 ?선?위 (?을?록 ?단 ?출)
  lastUpdated       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // 관?
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([productId, vendorId])
  @@index([productId])
  @@index([vendorId])
  @@index([priceInKRW])
  @@index([isPremiumFeatured, premiumPriority])
}

// #user-supplier-registration — 조직 단위 supplier-book.
//   한국 연구실 단위 거래처 명단 정합 (호영님 사업 확장 1단계).
//   - operator-input: vendorName / vendorEmail / vendorPhone / notes / isPrimary
//   - vendorId optional: 기존 platform Vendor table 연결 가능 (선택). 없어도
//     inline 만으로 동작 (operator 가 platform 미등록 vendor 도 등록 가능).
//   - createdById: audit (누가 등록했는지).
//   - @@unique([organizationId, vendorEmail]): 동일 조직 중복 차단.
//   - resolveSuppliers 의 'org_book' source 로 합산 (priority: recent_rfq →
//     org_book → supplier_book → ai_recommended).
model OrganizationVendor {
  id             String       @id @default(cuid())
  organizationId String
  vendorId       String?      // 기존 platform Vendor 연결 (optional)
  vendorName     String       // operator-input
  vendorEmail    String       // operator-input
  vendorPhone    String?
  isPrimary      Boolean      @default(false)  // 우선 거래처 marker
  // #vendor-partnership-tier — 조직 override (nullable).
  //   null 이면 Vendor.partnershipTier (글로벌 baseline) 사용 (overlay pattern).
  //   Phase 2 에서 settings/suppliers form 으로 입력. Phase 3 에서
  //   resolveSuppliers confidence boost 에 반영.
  partnershipTier VendorPartnershipTier?
  notes          String?      @db.Text         // 메모 (예: "신규 거래, 단가 협상 중")
  createdById    String       // audit — 누가 등록했는지
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([organizationId, vendorEmail])
  @@index([organizationId])
  @@index([vendorId])
  @@index([createdById])
}

// #vendor-catalog-product-matching Phase 1 — 조직 단위 vendor-product carry 매핑.
//   호영님 사업 확장 strategy 3단계 정합 (1단계 OrganizationVendor + 2단계
//   partnershipTier 위에 부착). operator 직접 입력 (Phase 2 UI), Phase 3 에서
//   resolveSuppliers 의 product 매칭 confidence boost 에 사용.
//   - organizationId × vendorId × productId 3-way unique.
//   - notes optional (operator memo).
//   - createdById audit (1단계 패턴).
//   - ProductVendor (platform-wide pricing) 와 의미 분리: ProductVendor 는
//     플랫폼 차원 catalog source, OrganizationVendorProduct 는 lab carry
//     record (어떤 vendor 가 어떤 product 를 organization 에 공급하는지).
model OrganizationVendorProduct {
  id             String       @id @default(cuid())
  organizationId String
  vendorId       String
  productId      String
  notes          String?      @db.Text
  createdById    String       // audit
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([organizationId, vendorId, productId])
  @@index([organizationId])
  @@index([vendorId])
  @@index([productId])
  @@index([createdById])
}

