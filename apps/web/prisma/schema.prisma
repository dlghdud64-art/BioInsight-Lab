// Purchase record (MVP: guestKey-based scope)
model PurchaseRecord {
  id              String   @id @default(cuid())
  scopeKey        String // guestKey for MVP, workspaceId for future
  workspaceId     String? // Optional workspace association
  quoteId         String? // Linked quote if source=quote
  purchasedAt     DateTime // Purchase date
  vendorName      String // Vendor name
  category              String?  // 원본 카테고리 문자열 (import/사용자 입력)
  normalizedCategoryId  String?  // FK → SpendingCategory.id (승인/PO 시점 고정)
  itemName              String   // Item/product name
  catalogNumber   String? // Catalog number
  unit            String? // Unit (ea, mL, g, etc.)
  qty             Int // Quantity
  unitPrice       Int? // Unit price (optional for import)
  amount          Int // Total amount (required)
  currency        String   @default("KRW")
  source          String   @default("import") // "import" or "quote"
  followUpStatus  String?  // null=pending, "inventory_reflected"=입고 반영 완료
  receivedAt      DateTime? // 입고 반영 완료 시각
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations (optional)
  quote              Quote?            @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  workspace          Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  normalizedCategory SpendingCategory? @relation(fields: [normalizedCategoryId], references: [id], onDelete: SetNull)

  @@index([scopeKey, purchasedAt])
  @@index([scopeKey, vendorName])
  @@index([scopeKey, category])
  @@index([normalizedCategoryId])
  @@index([quoteId])
  @@index([workspaceId])
}

// Budget management (Multi-tenant: organizationId-scoped)
model Budget {
  id             String   @id @default(cuid())
  organizationId String?  // FK to Organization (null = personal budget)
  teamId         String?  // FK to Team (null = no team scope) — optional sub-scope
  scopeKey       String   // Legacy: "user-{userId}" or "{organizationId}" (keep for backward compat)
  workspaceId    String?  // Optional workspace association
  yearMonth      String   // Format: "YYYY-MM" (e.g., "2025-01")
  amount         Int      // Budget amount
  currency       String   @default("KRW")
  description    String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([scopeKey, yearMonth])
  @@index([scopeKey])
  @@index([yearMonth])
  @@index([workspaceId])
  @@index([organizationId])
  @@index([teamId])
}

// Import job tracking (for file-based imports)
enum ImportJobStatus {
  PENDING // Queued for processing
  PROCESSING // Currently processing
  COMPLETED // Successfully completed
  FAILED // Failed with errors
  PARTIAL // Partially completed with errors
}

model ImportJob {
  id           String          @id @default(cuid())
  scopeKey     String // guestKey for MVP
  workspaceId  String? // Optional workspace association
  type         String // "purchase" (expandable to other types)
  filename     String // Original filename
  status       ImportJobStatus @default(PENDING)
  totalRows    Int             @default(0)
  successRows  Int             @default(0)
  errorRows    Int             @default(0)
  errorSample  Json? // Array of error samples
  result       Json? // Import result metadata
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([scopeKey])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([workspaceId])
}

// Workspace (minimal multi-tenant setup)
enum WorkspacePlan {
  FREE
  TEAM
  ENTERPRISE
}

enum WorkspaceMemberRole {
  ADMIN
  MEMBER
}

/// #mobile-push-notification Phase 1 server — mobile push token 저장.
/// mobile (Expo) 가 registerForPushNotifications 후 apiClient.post(
/// "/api/devices/register", { pushToken }) 호출. 동일 token 재등록 시
/// upsert (last seen update). lib/notifications/push-sender.ts 가
/// userId 기반 token list 조회 후 Expo Push API (exp.host) 호출.
model Device {
  id          String   @id @default(cuid())
  userId      String
  pushToken   String   @unique
  platform    String   // "ios" / "android" / "web"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum BillingStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model Workspace {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique // URL-friendly identifier
  plan             WorkspacePlan @default(FREE)
  lastWorkspaceId  String? // For user's last active workspace

  // Organization ↔ Workspace 1:1 bootstrap (옵션 B)
  // Phase 1: nullable + @unique 로 컬럼 추가 후 backfill.
  // Phase 2 (2026-04-17): NOT NULL 승격 완료. 모든 Workspace 는 정확히 하나의 Organization 에 속한다.
  // onDelete: Cascade — Organization 삭제 시 Workspace 도 같이 삭제. FK 를 들고 있는 이 쪽에 선언.
  organizationId   String        @unique
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Stripe billing fields
  stripeCustomerId        String? @unique
  stripeSubscriptionId    String? @unique
  stripePriceId           String?
  stripeCurrentPeriodEnd  DateTime?
  billingStatus           BillingStatus?

  /// §11.209d-approver-routing — 결재 임계치 (KRW). 이 금액 이상 결재
  /// 요청은 organization OWNER escalation. default 10,000,000 (1,000만원).
  /// admin UI 또는 /api/workspaces/[id] PATCH (ADMIN only) 로 변경.
  /// multi-tier (#approver-routing-multi-tier-threshold) 의 high tier 임계치.
  approvalThresholdKrw    Int     @default(10000000)
  /// #approver-routing-multi-tier-threshold — 중액/저액 구분 임계치 (KRW).
  /// amount < approvalLowThresholdKrw → workspace_admin (low),
  /// amount < approvalThresholdKrw → org_admin (mid), 이상 → org_owner (high).
  /// default 1,000,000 (100만원).
  ///
  /// #approver-routing-cross-field-validation-db-check-constraint — DB CHECK
  /// constraint workspace_approval_threshold_low_le_high 강제 (low_le_high):
  ///   CHECK (approvalLowThresholdKrw <= approvalThresholdKrw)
  /// migration SQL only (Prisma 표준 CHECK syntax 0). 4-layer defense in depth
  /// 의 마지막 lock — 직접 SQL / Prisma raw update 우회 차단.
  approvalLowThresholdKrw Int     @default(1000000)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  members          WorkspaceMember[]
  invites          WorkspaceInvite[]
  purchases        PurchaseRecord[]
  budgets          Budget[]
  quotes           Quote[]
  importJobs       ImportJob[]

  @@index([slug])
  // organizationId 는 @unique 가 자동 인덱스를 생성하므로 별도 @@index 불필요
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(MEMBER)
  /// #approver-routing-per-user-limit — 단일 건 결재 한도 (KRW). null =
  /// 무제한 (default). amount > approvalLimit 시 selectApproverByAmount
  /// 가 다음 fallback 으로 escalation. organization member 는 한도 무제한
  /// (별도 batch — 본 batch 는 workspace member 만).
  approvalLimit Int?
  /// #approver-routing-multi-owner-roundrobin — 마지막 결재 할당 timestamp.
  /// helper 가 orderBy lastApprovalAssignedAt asc nulls first + createdAt
  /// asc tie-breaker — 한 번도 안 받은 member 우선, 그 다음 가장 오래
  /// 안 받은 member. request-approval route 가 PR INSERT 후 candidate 의
  /// 본 field update (try/catch graceful).
  lastApprovalAssignedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  token       String    @unique // Unique invite token
  email       String
  role        WorkspaceMemberRole @default(MEMBER)
  expiresAt   DateTime // Invite expiration
  acceptedAt  DateTime? // When invite was accepted
  createdAt   DateTime  @default(now())

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([workspaceId])
  @@index([email])
}

// 조직 초대 링크
model OrganizationInvite {
  id               String           @id @default(cuid())
  organizationId   String
  token            String           @unique // URL-safe random invite token
  email            String?          // 특정 이메일 초대 (null이면 누구나 사용 가능)
  role             OrganizationRole @default(VIEWER)
  expiresAt        DateTime         // 만료 일시 (필수)
  acceptedAt       DateTime?        // 수락된 일시
  acceptedByUserId String?          // 수락한 유저 ID
  revokedAt        DateTime?        // 취소된 일시
  createdByUserId  String           // 생성한 관리자 ID
  createdAt        DateTime         @default(now())

  // 관계
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([organizationId])
}

// Stripe Webhook 멱등성 보장 테이블 (Task #40)
// Stripe 공식 권장 패턴: webhook endpoint는 같은 event 를 여러 번 받을 수 있음 (network retry,
// replay attack, at-least-once delivery). 처리 전에 event.id 를 PK 로 insert 해서 UNIQUE
// constraint violation (P2002) 이 발생하면 중복으로 간주하고 skip 한다.
// 참조: https://docs.stripe.com/webhooks (Handle duplicate events)
model StripeEvent {
  eventId     String   @id // Stripe event.id (예: evt_1Abc...)
  type        String   // Stripe event.type (예: customer.subscription.updated)
  processedAt DateTime @default(now())

  @@index([type])
  @@index([processedAt])
}

// 구독 정보 (Team/Org 플랜) - Production Level
model Subscription {
  id                   String           @id @default(cuid())
  organizationId       String?          @unique // 조직 기반 구독
  userId               String?          @unique // 개인 사용자 기반 구독
  workspaceId          String?          @unique // 워크스페이스 기반 구독
  plan                 SubscriptionPlan @default(FREE)
  status               String           @default("active") // active, trialing, past_due, canceled, unpaid
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean          @default(false)
  trialEndsAt          DateTime? // 체험판 종료일
  // Stripe 연동 필드
  stripeCustomerId     String? // Stripe 고객 ID
  stripeSubscriptionId String? // Stripe 구독 ID
  stripePriceId        String? // Stripe 가격 ID
  // 사용량 추적
  currentSeats         Int              @default(1) // 현재 시트 수
  maxSeats             Int? // 최대 시트 수 (플랜별 제한)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // 관계
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices       Invoice[] // 청구 내역
  paymentMethods PaymentMethod[] // 결제 수단

  @@index([organizationId])
  @@index([userId])
  @@index([workspaceId])
  @@index([status])
  @@index([stripeCustomerId])
}

// 결제 수단 (카드 정보)
model PaymentMethod {
  id             String   @id @default(cuid())
  subscriptionId String
  // Stripe 연동 필드
  stripePaymentMethodId String? @unique // Stripe PaymentMethod ID
  // 카드 정보 (표시용 - 실제 카드번호는 Stripe에 저장)
  brand          String? // visa, mastercard, amex 등
  last4          String? // 카드 마지막 4자리
  expMonth       Int? // 만료 월
  expYear        Int? // 만료 년
  // 상태
  isDefault      Boolean  @default(false) // 기본 결제 수단 여부
  isValid        Boolean  @default(true) // 유효 여부
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // 관계
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([isDefault])
}

// 청구서/인보이스
enum InvoiceStatus {
  DRAFT // 초안
  OPEN // 발행됨 (미결제)
  PAID // 결제 완료
  VOID // 취소됨
  UNCOLLECTIBLE // 수금 불가
}

model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String
  // Stripe 연동 필드
  stripeInvoiceId String?      @unique // Stripe Invoice ID
  // 청구 정보
  number         String? // 청구서 번호 (예: INV-2024-001)
  status         InvoiceStatus @default(DRAFT)
  amountDue      Int // 청구 금액 (원)
  amountPaid     Int           @default(0) // 결제된 금액
  currency       String        @default("KRW")
  // 기간 정보
  periodStart    DateTime // 청구 기간 시작
  periodEnd      DateTime // 청구 기간 종료
  dueDate        DateTime? // 결제 기한
  paidAt         DateTime? // 결제 완료 시점
  // 상세 내역
  description    String?       @db.Text // 청구 설명
  lineItems      Json? // 세부 항목 [{description, quantity, unitPrice, amount}]
  // PDF 영수증
  invoicePdfUrl  String? // PDF 다운로드 URL
  hostedInvoiceUrl String? // Stripe 호스팅 인보이스 URL
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // 관계
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([periodStart])
  @@index([stripeInvoiceId])
}

// 액티비티 로그 (P1+)
enum ActivityType {
  // ── 기존 사용자 행동 ──
  QUOTE_CREATED // 리스트 생성
  QUOTE_UPDATED // 리스트 수정
  QUOTE_DELETED // 리스트 삭제
  QUOTE_SHARED // 리스트 공유
  QUOTE_VIEWED // 리스트 조회
  QUOTE_STATUS_CHANGED // 견적 상태 변경
  PRODUCT_COMPARED // 제품 비교
  PRODUCT_VIEWED // 제품 조회
  PRODUCT_FAVORITED // 제품 즐겨찾기
  SEARCH_PERFORMED // 검색 수행

  // ── AI 파이프라인 활동 로그 (Closed-Loop) ──
  AI_TASK_CREATED            // AI 작업 생성 (AiActionItem PENDING)
  AI_TASK_OPENED             // AI 초안 미리보기 열림
  QUOTE_DRAFT_GENERATED      // 견적 초안 AI 생성 완료
  QUOTE_DRAFT_REVIEWED       // 견적 초안 검토 (승인/무시)
  EMAIL_DRAFT_GENERATED      // 벤더 이메일 초안 AI 생성 완료
  EMAIL_SENT                 // 이메일 발송 완료
  VENDOR_REPLY_LOGGED        // 벤더 회신 수신 기록
  ORDER_FOLLOWUP_GENERATED   // 주문 후속 이메일 초안 생성
  ORDER_FOLLOWUP_REVIEWED    // 주문 후속 이메일 검토 (승인/무시)
  ORDER_FOLLOWUP_SENT        // 주문 후속 이메일 발송 완료
  ORDER_STATUS_CHANGE_PROPOSED  // 주문 상태 변경 제안
  ORDER_STATUS_CHANGE_APPROVED  // 주문 상태 변경 승인
  ORDER_STATUS_CHANGED       // 주문 상태 변경 실행 (관리자)
  INVENTORY_RESTOCK_SUGGESTED   // 재발주 제안 생성
  INVENTORY_RESTOCK_REVIEWED    // 재발주 제안 검토
  PURCHASE_REQUEST_CREATED      // 구매 요청 생성
  PURCHASE_REQUEST_CANCELLED    // 구매 요청 취소
  PURCHASE_REQUEST_REVERSED     // 구매 요청 되돌림
  PURCHASE_RECORD_RECLASSIFIED  // 구매 레코드 재분류
  AI_TASK_COMPLETED          // AI 작업 최종 완료 (승인 후 실행 성공)
  AI_TASK_FAILED             // AI 작업 실패 (실행 에러)

  // ── Compare Workspace 확장 (V1-RC) ──
  QUOTE_DRAFT_STARTED_FROM_COMPARE  // 비교 세션에서 견적 초안 생성 시작
  COMPARE_INQUIRY_DRAFT_STATUS_CHANGED // 문의 초안 상태 변경
  COMPARE_RESULT_VIEWED              // 비교 결과 조회
  COMPARE_SESSION_REOPENED           // 비교 세션 재개 (판정 취소)
}

model ActivityLog {
  id             String       @id @default(cuid())
  userId         String? // 행위 수행자 (actor_id), null = 시스템 자동
  organizationId String? // 조직 격리 (org_id)
  activityType   ActivityType // action_type: 이벤트 종류
  entityType     String // entity_type: 대상 도메인 (AI_ACTION, QUOTE, INVENTORY 등)
  entityId       String? // entity_id: 대상 레코드 ID
  taskType       String? // AI 작업 타입 (QUOTE_DRAFT, VENDOR_EMAIL_DRAFT 등)
  beforeStatus   String? // 상태 전이 전 (PENDING, APPROVED 등)
  afterStatus    String? // 상태 전이 후
  actorRole      String? // 행위자 조직 역할 (ADMIN, APPROVER 등)
  metadata       Json? // 추가 메타데이터 (JSON)
  ipAddress      String? // IP 주소
  userAgent      String? // User Agent
  createdAt      DateTime     @default(now())

  // 관계
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([activityType])
  @@index([entityType])
  @@index([entityId])
  @@index([entityType, entityId]) // 특정 엔티티 이력 조회
  @@index([createdAt])
  @@index([taskType])
}

// ── Compare & Decision Workspace ──
model CompareSession {
  id             String   @id @default(cuid())
  productIds     Json     // string[] — 비교 대상 제품 ID
  diffResult     Json?    // DiffResult 구조 (structured diff)
  aiInsight      Json?    // AI 해석 결과
  userId         String?
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Decision record (V1-RC)
  decisionState  String?    // UNDECIDED | APPROVED | HELD | REJECTED
  decisionNote   String?    @db.Text
  decidedBy      String?
  decidedAt      DateTime?

  inquiryDrafts  CompareInquiryDraft[]

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
}

model CompareInquiryDraft {
  id               String   @id @default(cuid())
  compareSessionId String
  vendorName       String
  vendorEmail      String?
  productName      String
  subject          String
  body             String   @db.Text
  inquiryFields    Json     // string[]
  status           String   @default("GENERATED") // GENERATED | COPIED | SENT
  diffIndex        Int      @default(0)
  userId           String?
  organizationId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  compareSession   CompareSession @relation(fields: [compareSessionId], references: [id], onDelete: Cascade)

  @@index([compareSessionId])
  @@index([userId])
  @@index([status])
}

// 감사 로그 (Enterprise - 액티비티 로그 확장)
enum AuditEventType {
  USER_LOGIN // 사용자 로그인
  USER_LOGOUT // 사용자 로그아웃
  USER_CREATED // 사용자 생성
  USER_UPDATED // 사용자 수정
  USER_DELETED // 사용자 삭제
  PERMISSION_CHANGED // 권한 변경
  SETTINGS_CHANGED // 설정 변경
  DATA_EXPORTED // 데이터 내보내기
  DATA_IMPORTED // 데이터 가져오기
  SSO_CONFIGURED // SSO 설정
  ORGANIZATION_CREATED // 조직 생성
  ORGANIZATION_UPDATED // 조직 수정
  ORGANIZATION_DELETED // 조직 삭제

  // ── Package A: Ingestion Pipeline Events ──
  INGESTION_RECEIVED              // 외부 입력 수신
  DOCUMENT_CLASSIFIED             // AI 문서 분류 완료
  EXTRACTION_COMPLETED            // AI 필드 추출 완료
  ENTITY_LINKED                   // DB Entity 연결 완료
  VERIFICATION_COMPLETED          // 검증 완료 (auto_verified/review_needed/mismatch/missing)
  WORK_QUEUE_TASK_GENERATED       // Ingestion → Work Queue Task 생성

  // ── #approver-routing-event-type-enum-add (#11.209d-approver-routing) ──
  // 결재 라우팅 dedicated audit events — 직전 audit-log batch 의 generic
  // (SETTINGS_CHANGED / WORK_QUEUE_TASK_GENERATED) 재사용 → 의미 명확화.
  WORKSPACE_THRESHOLD_CHANGED     // workspace 결재 임계치 변경 (low/high)
  PURCHASE_REQUEST_CREATED        // PR INSERT + 결재 매핑 (source/appliedThresholds)

  // ── #approver-routing-per-user-limit-audit-log ──
  MEMBER_APPROVAL_LIMIT_CHANGED   // workspace member 결재 한도 변경 (per-user)

  // ── #audit-event-type-order (#post-approval-purchase-order-flow cluster cleanup) ──
  // dedicated audit events — 직전 cluster 의 SETTINGS_CHANGED 재사용
  // (Phase 1.3 / 2.2 / 3.2) → 의미 명확화. audit UI filter / grep 정합.
  ORDER_CREATED_FROM_POCANDIDATE  // POCandidate 결재 통과 시 vendor 별 Order 자동 생성
  PO_PDF_GENERATED                // vendor 별 PO 발주서 PDF 생성 (stream 다운로드)
  VENDOR_EMAIL_SENT               // 공급사 발주 email 송부 (한글 본문)
}

model AuditLog {
  id             String         @id @default(cuid())
  organizationId String? // 조직 ID (Enterprise)
  userId         String? // 사용자 ID
  eventType      AuditEventType // 이벤트 유형
  entityType     String // 엔티티 유형
  entityId       String? // 엔티티 ID
  action         String // 액션 (create, update, delete, view 등)
  changes        Json? // 변경 사항 (before/after)
  metadata       Json? // 추가 메타데이터
  ipAddress      String? // IP 주소
  userAgent      String? // User Agent
  success        Boolean        @default(true) // 성공 여부
  errorMessage   String?        @db.Text // 오류 메시지
  createdAt      DateTime       @default(now())

  // 관계
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([eventType])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([success])
}

// §11.246d-4-cont #rum-metric-db-persistence — Core Web Vitals 4 metric 영속화.
//
//   §11.246d-3 observeLCP + §11.246d-5 observeCLS/FID/INP client RUM 측정 →
//   §11.246d-4 server POST endpoint (zod validation + structured log) →
//   본 model 으로 raw row 영속화. p75 aggregate view 는 별도 백로그.
//
//   4 metric Float? — client beacon 도 모두 optional (browser 미지원 graceful
//   fallback). FK 강제 0 — anonymous RUM 강제. session correlation 보류.
model RumMetric {
  id        String   @id @default(cuid())
  lcp       Float?   // Largest Contentful Paint (ms)
  cls       Float?   // Cumulative Layout Shift (unitless)
  fid       Float?   // First Input Delay (ms)
  inp       Float?   // Interaction to Next Paint (ms)
  pathname  String?  // page route (max 500 chars zod)
  userAgent String?  // user agent (max 500 chars zod)
  sessionId String?  // anonymous session marker (max 64 chars zod, optional)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([pathname])
  @@index([lcp])
  @@index([cls])
  @@index([inp])
}

// #cron-monitoring-admin-dashboard — Vercel cron 실행 history (admin dashboard).
//   호영님 backlog audit P0 (b). §11.250b-fix 같은 dead cron 사건 사전 감지.
//   각 cron route handler 를 logCronExecution 으로 wrap → 본 table INSERT.
//   admin/cron page 가 본 model 을 시각화 (last execution / success rate / p95).
model CronExecutionLog {
  id            String    @id @default(cuid())
  cronPath      String    // e.g. "/api/cron/inventory-check"
  startedAt     DateTime  // handler 진입 시각
  completedAt   DateTime? // handler 완료 시각 (try/finally 보장)
  durationMs    Int       // completedAt - startedAt (ms). 실패 시도 계산.
  success       Boolean   // true = handler resolved, false = throw
  errorMessage  String?   @db.Text // catch 된 Error.message (truncated)
  metadata      Json?     // handler 결과 또는 contextual data (선택적)
  createdAt     DateTime  @default(now())

  @@index([cronPath])
  @@index([startedAt])
  @@index([success])
}

// RFQ Token for email-based quote replies
model QuoteRfqToken {
  id        String    @id @default(cuid())
  quoteId   String    @unique // One token per quote
  token     String    @unique // URL-safe random token (32-48 chars)
  enabled   Boolean   @default(true) // Can disable without deleting
  expiresAt DateTime? // Optional expiration
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([enabled])
}

// Inbound email status
enum InboundEmailStatus {
  MATCHED // Successfully matched to a quote
  UNMATCHED // No matching token found
  FAILED // Processing error
}

// Inbound email log (for webhook processing)
model InboundEmail {
  id              String             @id @default(cuid())
  provider        String             @default("sendgrid") // Email provider
  messageId       String             @unique // Email Message-ID for deduplication
  to              String // Recipient address
  from            String // Sender address
  subject         String
  text            String?            @db.Text // Plain text body
  html            String?            @db.Text // HTML body
  rawHeaders      Json? // Raw email headers
  attachmentsMeta Json? // Attachment metadata
  matchedQuoteId  String? // Matched quote (if status=MATCHED)
  status          InboundEmailStatus @default(UNMATCHED)
  receivedAt      DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Relations
  matchedQuote Quote? @relation(fields: [matchedQuoteId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([status])
  @@index([matchedQuoteId])
  @@index([receivedAt])
}

// Quote reply from vendor (via email)
model QuoteReply {
  id          String   @id @default(cuid())
  quoteId     String
  vendorName  String? // Nullable, can be extracted from email
  fromEmail   String // Sender email
  subject     String
  receivedAt  DateTime @default(now())
  bodyText    String?  @db.Text // Plain text body
  bodyHtml    String?  @db.Text // HTML body
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  quote       Quote                 @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  attachments QuoteReplyAttachment[]

  @@index([quoteId])
  @@index([fromEmail])
  @@index([receivedAt])
}

// Attachments for quote replies
model QuoteReplyAttachment {
  id          String   @id @default(cuid())
  replyId     String
  fileName    String
  contentType String?
  sizeBytes   Int
  bucket      String // Supabase storage bucket name
  path        String // Storage path
  createdAt   DateTime @default(now())

  // Relations
  reply QuoteReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@index([replyId])
}

// Vendor information for quotes (optional, can be added later)
model QuoteVendor {
  id          String   @id @default(cuid())
  quoteId     String
  vendorName  String
  email       String?
  country     String?  @default("KR")
  memo        String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([vendorName])
}

// Public share configuration for quotes (optional for phase B)
model QuoteShare {
  id          String    @id @default(cuid())
  quoteId     String    @unique // One share per quote
  shareToken  String    @unique // URL-safe random token for public access
  expiresAt   DateTime? // Optional expiration
  enabled     Boolean   @default(true) // Can disable without deleting
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([shareToken])
  @@index([enabled])
}

// Vendor request status enum
enum VendorRequestStatus {
  SENT       // Initial state after sending
  RESPONDED  // Vendor has submitted response
  EXPIRED    // Past expiration date
  CANCELLED  // Cancelled by internal user
}

// Vendor request (견적 요청 발송 단위)
model QuoteVendorRequest {
  id                String              @id @default(cuid())
  quoteId           String // FK to Quote (견적요청서)
  vendorName        String? // Optional vendor name
  vendorEmail       String? // Vendor email (null = manual/offline reply)
  message           String?             @db.Text // Request message
  token             String              @unique // Public access token (32-48 chars random)
  status            VendorRequestStatus @default(SENT)
  expiresAt         DateTime // Default 14 days from creation
  respondedAt       DateTime? // When vendor submitted response (initial submission)
  responseEditCount Int                 @default(0) // Number of times response was edited
  responseEditLimit Int                 @default(1) // Maximum allowed edits
  snapshot          Json // Frozen snapshot of quote + items at request time
  snapshotCreatedAt DateTime            @default(now()) // When snapshot was taken
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Relations
  quote         Quote                      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  responseItems QuoteVendorResponseItem[]

  @@index([quoteId])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

// Vendor response item (품목별 회신)
model QuoteVendorResponseItem {
  id               String   @id @default(cuid())
  vendorRequestId  String // FK to QuoteVendorRequest
  quoteItemId      String // FK to QuoteListItem
  unitPrice        Int? // Response unit price (KRW precision)
  currency         String   @default("KRW")
  leadTimeDays     Int? // Lead time in days
  moq              Int? // Minimum order quantity (optional)
  vendorSku        String? // Vendor's SKU/catalog number (optional)
  notes            String?  @db.Text // Vendor notes (optional)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  vendorRequest QuoteVendorRequest @relation(fields: [vendorRequestId], references: [id], onDelete: Cascade)
  quoteItem     QuoteListItem      @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)

  @@unique([vendorRequestId, quoteItemId])
  @@index([vendorRequestId])
  @@index([quoteItemId])
}

// =====================================================
// 주문 및 예산 관리 모델
// =====================================================

// 주문 상태
enum OrderStatus {
  ORDERED   // 주문 완료
  CONFIRMED // 확인됨
  SHIPPING  // 배송 중
  DELIVERED // 배송 완료
  CANCELLED // 취소됨
}

// 주문 (Order)
// #post-approval-purchase-order-flow Phase 1.2 — vendor 별 PO 분리 (option A).
// canonical truth = Order (DB) — 결재 후 vendor 별 발주서. 1 Quote → N Order
// (vendor 별). legacy data 의 vendorId NULL backward compat.
//
// `quoteId @unique` (단독) → composite `@@unique([quoteId, vendorId])` 로 swap.
// vendor 별 1개 Order 보장 (legacy NULL row 는 1 quote 1 NULL Order 유지).
//
// vendor / poCandidate relation 은 SetNull on delete — Order 보존.
model Order {
  id             String      @id @default(cuid())
  userId         String
  quoteId        String      // composite unique 로 변경 (`@@unique([quoteId, vendorId])`)
  vendorId       String?     // vendor 별 발주서 매핑. legacy = NULL.
  poCandidateId  String?     // POCandidate 1:1 매핑. SetNull on delete.
  organizationId String?
  orderNumber    String      @unique // 주문번호 (ORD-YYYYMMDD-XXXX)
  totalAmount    Int         // 총 주문 금액 (KRW)
  status         OrderStatus @default(ORDERED)
  notes          String?     @db.Text // 주문 메모
  shippingAddress String?    @db.Text // 배송 주소
  expectedDelivery DateTime? // 예상 배송일
  actualDelivery  DateTime?  // 실제 배송일
  // #post-approval-purchase-order-flow Phase 2.3 step 1 — PDF 영속화.
  // step 2 (storage upload) 별도 mini-batch — host config (S3/Cloudinary
  // /Supabase) 후 generate-pdf route 가 upload 결과 URL 저장.
  poDocumentUrl       String?  @db.Text // 발주서 PDF storage URL (NULL = 미생성)
  poDocumentGeneratedAt DateTime? // PDF 생성 시각 (재생성 정합)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote           Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  vendor          Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  poCandidate     POCandidate?        @relation(fields: [poCandidateId], references: [id], onDelete: SetNull)
  organization    Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  purchaseRequest PurchaseRequest?    @relation("PurchaseRequestOrder") // 역방향 relation (PurchaseRequest.orderId -> Order.id)
  items           OrderItem[]
  restocks        InventoryRestock[]  // P7-1: 입고 기록
  budgetTransaction UserBudgetTransaction?
  // §11.348-A — 발주 후 입고 회신(검증 대기 입고안). 1 PO ↔ N draft.
  receivingDrafts   ReceivingDraft[]

  @@unique([quoteId, vendorId]) // vendor 별 1개 Order — legacy NULL row 도 1개 보장
  @@index([userId])
  @@index([quoteId])
  @@index([vendorId])
  @@index([poCandidateId])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

// 주문 품목
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  name        String   // 제품명
  brand       String?  // 브랜드
  catalogNumber String? // 카탈로그 번호
  quantity    Int      @default(1)
  unitPrice   Int      // 단가
  lineTotal   Int      // 품목 합계 (단가 x 수량)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

// 사용자 예산 (UserBudget) - 연구비 계좌
model UserBudget {
  id              String   @id @default(cuid())
  userId          String
  organizationId  String?
  name            String   @default("연구비") // 예산 이름 (예: "2024년 연구비", "실험실 운영비")
  totalAmount     Int      // 총 예산 (KRW)
  usedAmount      Int      @default(0) // 사용된 금액
  remainingAmount Int      // 잔액 (totalAmount - usedAmount)
  currency        String   @default("KRW")
  fiscalYear      Int?     // 회계연도 (예: 2024)
  startDate       DateTime? // 예산 시작일
  endDate         DateTime? // 예산 종료일
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  transactions  UserBudgetTransaction[]

  @@index([userId])
  @@index([organizationId])
  @@index([isActive])
  @@index([fiscalYear])
}

// 예산 거래 내역
model UserBudgetTransaction {
  id          String   @id @default(cuid())
  budgetId    String
  orderId     String?  @unique // 주문과 연결된 경우
  type        String   // "DEBIT" (차감), "CREDIT" (입금/환불)
  amount      Int      // 거래 금액
  description String?  // 거래 설명
  balanceBefore Int    // 거래 전 잔액
  balanceAfter  Int    // 거래 후 잔액
  createdAt   DateTime @default(now())

  // Relations
  budget UserBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  order  Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([budgetId])
  @@index([orderId])
  @@index([type])
  @@index([createdAt])
}

// =====================================================
// §11.101 #userInventory-schema-drop
// UserInventory model 제거됨. canonical 운영 master 는 ProductInventory.
// §11.58 #inventory-model-consolidation Phase 1~4 에서 application code
// 는 모두 ProductInventory 로 정렬 완료. 본 schema drop 으로 silent shape
// drift 회귀 가능성 영구 차단.
// =====================================================

// =====================================================
// 팀/랩 관리 (Team/Lab)
// =====================================================

// 팀/랩
model Team {
  id             String   @id @default(cuid())
  organizationId String?  // FK to Organization (null = standalone team)
  name           String
  description    String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members          TeamMember[]
  purchaseRequests PurchaseRequest[]
  budgets          Budget[]

  @@index([organizationId])
  @@index([name])
}

// 팀 멤버
model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
  @@index([role])
}

// =====================================================
// 구매 요청 시스템 (Purchase Request)
// =====================================================

// 구매 요청
model PurchaseRequest {
  id          String                @id @default(cuid())
  requesterId String                // 요청자 ID
  approverId  String?               // 승인자 ID (nullable)
  teamId      String?               // 팀 ID
  status      PurchaseRequestStatus @default(PENDING)
  title       String                // 요청 제목
  message     String?               @db.Text // 요청 메시지/메모
  items       Json                  // 요청 품목 (JSON)
  totalAmount Int?                  // 총 금액
  quoteId     String?               // 연결된 견적 ID (선택적)
  orderId     String?  @unique       // 승인 후 생성된 주문 ID
  rejectedAt  DateTime?             // 거절 시각
  rejectedReason String?            @db.Text // 거절 사유
  approvedAt DateTime?              // 승인 시각
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  // Relations
  requester User    @relation("RequestedPurchases", fields: [requesterId], references: [id], onDelete: Cascade)
  approver  User?   @relation("ApprovedPurchases", fields: [approverId], references: [id], onDelete: SetNull)
  team      Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  quote     Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  order     Order?  @relation("PurchaseRequestOrder", fields: [orderId], references: [id], onDelete: SetNull)

  @@index([requesterId])
  @@index([approverId])
  @@index([teamId])
  @@index([status])
  @@index([createdAt])
}

// =====================================================
// 장바구니 (Cart) - Re-order Flywheel
// =====================================================

// 장바구니
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique // 사용자당 하나의 장바구니
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
}

// 장바구니 아이템
model CartItem {
  id            String   @id @default(cuid())
  cartId        String
  productId     String?  // 제품 ID (있으면 연결)
  productName   String   // 제품명
  brand         String?  // 브랜드
  catalogNumber String?  // 카탈로그 번호
  quantity      Int      @default(1) // 수량
  unitPrice     Int?     // 단가 (KRW)
  notes         String?  @db.Text
  sourceType    String   @default("MANUAL") // MANUAL, REORDER, SEARCH
  sourceId      String?  // 원본 ID (재주문 시 inventoryId 등)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  cart    Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([cartId, catalogNumber]) // 같은 카탈로그 번호는 하나만
  @@index([cartId])
  @@index([productId])
  @@index([catalogNumber])
}

// ─── DataAuditLog: CRUD 데이터 추적성(Traceability) ──────────────────────────
// 재고·예산·견적·조직 등 주요 도메인의 CREATE/UPDATE/DELETE 이력을 보관.
// ActivityLog(사용자 행동 로그)·AuditLog(시스템 이벤트)와 역할이 다름.

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntityType {
  INVENTORY          // 재고 수량·메타 수정
  INVENTORY_RESTOCK  // 입고 처리
  INVENTORY_USE      // 출고(사용) 처리
  BUDGET             // 예산 생성·변경·차감
  QUOTE              // 견적 생성·수정·삭제
  QUOTE_STATUS       // 견적 상태 변경(구매 완료 등)
  USER               // 사용자 생성·수정·삭제
  ORGANIZATION       // 조직 설정 변경
  SETTINGS           // 시스템 설정 변경
  INSPECTION         // 점검 기록 생성
  AI_ACTION          // AI 작업 승인·무시·실행
}

model DataAuditLog {
  id             String          @id @default(cuid())
  organizationId String?                          // 조직 격리용 FK (RLS)
  userId         String?                          // 행위 수행자 (null = 시스템 자동)
  action         AuditAction                      // CREATE | UPDATE | DELETE
  entityType     AuditEntityType                  // 대상 도메인
  entityId       String                           // 변경 대상 레코드 ID
  previousData   Json?                            // UPDATE·DELETE 시 변경 전 스냅샷
  newData        Json?                            // CREATE·UPDATE 시 변경 후 스냅샷
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime        @default(now())

  // Relations
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([entityType, entityId]) // 특정 엔티티 이력 조회 최적화
  @@index([createdAt])
}

// ─── 청구 정보 (BillingInfo) ──────────────────────────
// 조직별 세금계산서·결제 청구 담당자 정보
model BillingInfo {
  id                 String   @id @default(cuid())
  organizationId     String   @unique
  companyName        String                  // 회사명 (세금계산서용)
  businessNumber     String?                 // 사업자등록번호
  representativeName String?                 // 대표자명
  contactName        String                  // 담당자명
  contactEmail       String                  // 청구 이메일
  contactPhone       String?                 // 연락처
  address            String?                 // 주소
  taxInvoiceEmail    String?                 // 세금계산서 수신 이메일 (별도)
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ══════════════════════════════════════════════════════════
// Package A — 통합 AI 운영 레이어 (Ingestion → Audit Trail)
// ══════════════════════════════════════════════════════════

/// A-1. 외부 입력 소스 유형
enum IngestionSourceType {
  EMAIL              // 이메일 수신 (SendGrid webhook 등)
  ATTACHMENT         // 이메일 첨부파일
  UPLOAD             // 사용자 직접 업로드
  SYSTEM             // 시스템 연동 (ERP, 외부 API 등)
}

/// A-2. 문서 분류 유형 — AI Classification 결과
enum DocumentType {
  VENDOR_QUOTE              // 벤더 견적서
  VENDOR_REPLY              // 벤더 회신 (일반)
  INVOICE                   // 세금계산서 / 인보이스
  TRANSACTION_STATEMENT     // 거래명세서
  PURCHASE_ORDER_DOCUMENT   // 발주서
  DELIVERY_UPDATE           // 배송/납기 안내
  RECEIVING_DOCUMENT        // 입고 확인서 / 수령증
  UNKNOWN                   // 미분류
}

/// A-5. 검증 상태 — Entity Linking 후 교차 검증 결과
enum VerificationStatus {
  AUTO_VERIFIED      // 링크 명확 + 핵심 필드 일치
  REVIEW_NEEDED      // 링크 가능하나 일부 필드 불명확
  MISMATCH           // 연결됨, 핵심 필드 충돌 (금액/수량 등)
  MISSING            // 필수 문서/필드 누락
}

/// A-6. Ingestion → Work Queue 매핑용 Task Type
enum IngestionTaskType {
  PURCHASE_EVIDENCE_REVIEW  // 구매 증빙 교차 검토
  INVOICE_MISSING           // 세금계산서 누락
  DOCUMENT_MISMATCH         // 문서 간 불일치 (금액, 수량)
  VENDOR_REPLY_REVIEW       // 벤더 회신 검토 필요
  DELIVERY_UPDATE_REVIEW    // 배송/납기 변경 검토
}

/// A-7. 파이프라인 감사 이벤트 유형
enum IngestionAuditAction {
  INGESTION_RECEIVED               // 외부 입력 수신
  DOCUMENT_CLASSIFIED              // AI 문서 분류 완료
  EXTRACTION_COMPLETED             // AI 필드 추출 완료
  ENTITY_LINKED                    // DB Entity 연결 완료
  VERIFICATION_AUTO_VERIFIED       // 자동 검증 통과
  VERIFICATION_REVIEW_REQUESTED    // 수동 검토 요청
  VERIFICATION_MISMATCH_DETECTED   // 불일치 감지
  VERIFICATION_MISSING_DETECTED    // 필수 항목 누락 감지
  WORK_QUEUE_TASK_CREATED          // Work Queue Task 생성
}

/// A-1. IngestionEntry — 모든 외부 입력의 공통 진입점
/// 이메일, 첨부파일, 업로드, 시스템 연동 등 모든 소스가 이 모델을 통해 파이프라인에 진입
model IngestionEntry {
  id                      String               @id @default(cuid())
  organizationId          String
  sourceType              IngestionSourceType
  sourceRef               String?              // 원본 참조 (InboundEmail.id, Upload URL 등)
  filename                String?
  mimeType                String?
  receivedAt              DateTime             @default(now())
  uploaderId              String?              // 업로드한 사용자 (SYSTEM 소스일 경우 null)

  // ── AI Classification 결과 (A-2) ──
  documentType            DocumentType         @default(UNKNOWN)
  classificationConfidence Float?              // 0.0 ~ 1.0
  classifiedAt            DateTime?

  // ── AI Extraction 결과 (A-3, JSON 저장) ──
  rawTextRef              String?              @db.Text  // 원본 텍스트 or S3 key
  extractionResult        Json?                // ExtractionResult JSON (A-3 Interface 준수)
  extractedAt             DateTime?

  // ── Entity Linking 결과 (A-4) ──
  linkedEntityType        String?              // "QUOTE" | "ORDER" | "PURCHASE" | "INVENTORY"
  linkedEntityId          String?
  linkingConfidence       Float?               // 0.0 ~ 1.0
  linkedAt                DateTime?

  // ── Verification 결과 (A-5) ──
  verificationStatus      VerificationStatus?
  verificationReason      String?              // 판정 사유 (자동 생성 설명)
  mismatchedFields        Json?                // ["total_amount", "quantity"] 등
  missingFields           Json?                // ["invoice_number", "tax_amount"] 등
  verifiedAt              DateTime?

  // ── Work Queue 연동 (A-6) ──
  workQueueTaskId         String?              // 생성된 AiActionItem.id (1:1 참조)
  workQueueTaskType       IngestionTaskType?   // 매핑된 Task Type

  // ── Policy Hook (가드레일 신호) ──
  policyFlags             Json?                // { "budget_exceeded": true, "amount_threshold": 5000000 }
  approvalRequired        Boolean              @default(false)

  // ── Metadata ──
  metadata                Json?                // 소스별 추가 정보 (이메일 헤더, 업로드 경로 등)
  errorMessage            String?              @db.Text

  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  // Relations
  organization            Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploader                User?                @relation("IngestionUploader", fields: [uploaderId], references: [id], onDelete: SetNull)
  auditTrail              IngestionAuditLog[]

  @@index([organizationId, documentType])        // 조직별 문서 유형 조회
  @@index([organizationId, verificationStatus])  // 조직별 검증 상태 필터
  @@index([linkedEntityType, linkedEntityId])    // Entity 역추적
  @@index([sourceRef])                           // 원본 소스 역참조
  @@index([receivedAt])
  @@index([createdAt])
}

/// A-7. IngestionAuditLog — 파이프라인 단계별 감사 추적
/// 각 IngestionEntry가 Classification → Extraction → Linking → Verification을 거칠 때마다 기록
model IngestionAuditLog {
  id                String                @id @default(cuid())
  ingestionEntryId  String
  action            IngestionAuditAction
  actorType         String                @default("SYSTEM")  // "SYSTEM" | "USER"
  actorId           String?               // User ID (수동 검토 시)

  // 단계별 스냅샷
  before            Json?                 // 변경 전 상태 스냅샷
  after             Json?                 // 변경 후 상태 스냅샷
  confidence        Float?                // 해당 단계 AI Confidence
  durationMs        Int?                  // 처리 소요 시간 (ms)
  errorMessage      String?               @db.Text

  createdAt         DateTime              @default(now())

  // Relations
  ingestionEntry    IngestionEntry        @relation(fields: [ingestionEntryId], references: [id], onDelete: Cascade)

  @@index([ingestionEntryId, action])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════
// AI Action Pipeline — 운영형 에이전트 (Human-in-the-Loop)
// ══════════════════════════════════════════════════════════

enum AiActionType {
  QUOTE_DRAFT            // RFQ 이메일 초안
  VENDOR_EMAIL_DRAFT     // 벤더별 이메일 초안
  REORDER_SUGGESTION     // 재발주 제안
  EXPIRY_ALERT           // 만료 임박 알림
  FOLLOWUP_DRAFT         // 후속 이메일 초안
  VENDOR_RESPONSE_PARSED // 벤더 회신 파싱 결과
  STATUS_CHANGE_SUGGEST  // 상태 변경 제안
  COMPARE_DECISION       // 비교 세션 판정 대기
  RATIONALE_SUMMARY      // α-F (ADR §11.25) — AI 선택안 단일 라인 근거
}

// ── Legacy 상태 (하위 호환) ──
enum AiActionStatus {
  PENDING     // 승인 대기
  APPROVED    // 승인 완료
  DISMISSED   // 무시됨
  EXPIRED     // 자동 만료
  EXECUTING   // 승인 후 실행 중
  FAILED      // 실행 실패
}

enum AiActionPriority {
  HIGH
  MEDIUM
  LOW
}

// ══════════════════════════════════════════════════════════
// Unified Work Queue — 3-Layer 상태 분리
// ══════════════════════════════════════════════════════════

/// 글로벌 작업 상태 — 대시보드 필터/배지/정렬의 유일한 기준
enum TaskStatus {
  READY              // 초안 생성 완료, 검토 대기
  REVIEW_NEEDED      // 사용자 검토(승인/수정) 필요
  IN_PROGRESS        // 실행 중 (API 호출, 이메일 발송 등)
  WAITING_RESPONSE   // 외부 응답 대기 (벤더 회신 등)
  ACTION_NEEDED      // 즉시 조치 필요 (임박 알림, 재발주)
  COMPLETED          // 최종 완료
  FAILED             // 실행 실패
  BLOCKED            // 선행 조건 미충족 (예산 부족, 권한 없음)
}

/// 결재/승인 상태 — TaskStatus와 독립 조합
enum ApprovalStatus {
  NOT_REQUIRED       // 승인 불필요 (알림 확인 등)
  PENDING            // 승인 대기 중
  APPROVED           // 승인됨
  REJECTED           // 거절됨 (= DISMISSED)
}

/// §11.209b-pre — 결재 정책 (workspace / PO candidate 단위 default).
/// POCandidate.approvalPolicy 의 String → enum 변환 (옵션 B 정합 — schema 만
/// 통일, application code 의 string literal 그대로 호환). 다른 enum drift
/// (guardrail.ts / quote-case-contract 의 "in_app_light" / "external_manual"
/// 등) 정합은 별도 cluster 분리.
enum ApprovalPolicy {
  none               // 결재 불필요 (Lab Team Tier default)
  in_app_approval    // LabAxis 내부 결재 (R&D Operations Tier default)
  external_approval  // 외부 ERP/그룹웨어 결재 (Enterprise Tier 옵션)
}

/// §11.99b — POCandidate 단위 결재 상태. AiActionItem.approvalStatus 의
/// ApprovalStatus enum (4 값 UPPER_CASE) 과 별개 — POCandidate 의 결재 흐름은
/// 더 세분화된 8 단계 (procurement-stage.ts 의 ApprovalStatus type alias 어휘
/// 정합). 옵션 A — 별도 enum 이름 (POCandidateApprovalStatus) 으로 충돌 회피.
enum POCandidateApprovalStatus {
  not_required                  // 결재 불필요
  external_approval_required    // 외부 결재 필요
  external_approval_pending     // 외부 결재 대기 중
  externally_approved           // 외부 결재 완료
  externally_rejected           // 외부 결재 반려
  in_app_approval_pending       // 내부 결재 대기 중
  in_app_approved               // 내부 결재 완료
  in_app_rejected               // 내부 결재 반려
}

model AiActionItem {
  id                String           @id @default(cuid())
  type              AiActionType
  status            AiActionStatus   @default(PENDING)   // Legacy — 기존 API 하위 호환
  priority          AiActionPriority @default(MEDIUM)

  // ── 3-Layer 상태 분리 ──
  taskStatus        TaskStatus       @default(READY)            // L1: 글로벌 작업 상태
  approvalStatus    ApprovalStatus   @default(NOT_REQUIRED)     // L2: 결재 상태
  substatus         String?          // L3: 도메인 세부 상태 (quote_draft_generated, order_followup_sent 등)

  userId            String
  organizationId    String?
  assigneeId        String?          // 담당자 (조직 내 할당 가능)

  title             String           // 표시 제목 (예: "Anti-CD3 항체 외 3건 견적 초안")
  summary           String?          // 1줄 요약 (대시보드 카드 서브텍스트)
  description       String?          @db.Text
  payload           Json             // 초안 데이터 (이메일 본문, 품목 리스트 등)
  result            Json?            // 실행 결과 (생성된 quoteId 등)

  relatedEntityType String?          // "QUOTE", "ORDER", "INVENTORY"
  relatedEntityId   String?          // 관련 레코드 ID

  aiModel           String?          // 사용된 AI 모델 (예: "gpt-4o")
  promptTokens      Int?             // 토큰 사용량 추적
  completionTokens  Int?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  expiresAt         DateTime?        // 자동 만료 시각
  resolvedAt        DateTime?        // 승인/무시 처리 시각
  resolvedBy        String?          // 처리한 사용자 ID
  completedAt       DateTime?        // 최종 완료 시각
  failedAt          DateTime?        // 실패 시각

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([organizationId, status])
  @@index([organizationId, taskStatus])  // 대시보드 Work Queue 조회
  @@index([taskStatus, priority])         // 상태별 우선순위 정렬
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

// ══════════════════════════════════════════════════════════
// P0 Runtime — Canary Rollout & AI Processing Observability
// ══════════════════════════════════════════════════════════

enum CanaryStage {
  SHADOW      // AI 실행하되 결과 미적용, 비교 로그만
  ACTIVE_5    // 5% 트래픽에 AI 적용
  ACTIVE_25   // 25% 트래픽에 AI 적용
  ACTIVE_50   // 50% 트래픽에 AI 적용
  STABLE      // 100% AI 적용
  KILLED      // Kill switch 발동 — 0% AI
}

enum ProcessingPath {
  AI
  FALLBACK
  SHADOW
}

enum FallbackReason {
  NONE
  TIMEOUT
  SCHEMA_INVALID
  LOW_CONFIDENCE
  PROVIDER_ERROR
  KILL_SWITCH
  FEATURE_FLAG_OFF
  AUTO_VERIFY_BLOCKED
}

// 문서 타입별 Canary 설정
model CanaryConfig {
  id                   String      @id @default(cuid())
  documentType         String      @unique // QUOTE, INVOICE, ORDER, PURCHASE_ORDER
  stage                CanaryStage @default(SHADOW)
  confidenceThreshold  Float       @default(0.8)
  autoVerifyEnabled    Boolean     @default(false)
  killSwitchActive     Boolean     @default(false)
  updatedBy            String      // userId
  reason               String?     @db.Text
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([documentType])
  @@index([stage])
}

// Canary 조작 이력 (promote/hold/rollback/kill)
model CanaryApprovalRecord {
  id             String   @id @default(cuid())
  documentType   String
  action         String   // PROMOTE, HOLD, ROLLBACK, KILL_SWITCH_ON, KILL_SWITCH_OFF, AUTO_VERIFY_ON, AUTO_VERIFY_OFF
  fromStage      String?
  toStage        String?
  performedBy    String   // userId
  reason         String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([documentType])
  @@index([performedBy])
  @@index([createdAt])
}

// AI 처리 로그 (observability)
model AiProcessingLog {
  id                String         @id @default(cuid())
  ingestionEntryId  String?
  organizationId    String
  documentType      String
  processingPath    ProcessingPath
  fallbackReason    FallbackReason @default(NONE)
  confidence        Float?
  model             String?        // gpt-4o-mini, gpt-4o
  latencyMs         Int?
  tokenUsage        Int?
  comparisonDiff    Json?          // shadow mode: AI vs rule-based diff
  mismatchCategory  String?        // FIELD_VALUE_DIFF, MISSING_FIELD, etc.
  rollbackTriggered Boolean        @default(false)
  incidentTriggered Boolean        @default(false)
  createdAt         DateTime       @default(now())

  @@index([organizationId, documentType])
  @@index([processingPath])
  @@index([createdAt])
  @@index([incidentTriggered])
}

// ════════════════════════════════════════════════════════════════════
// P1-1 Slice-1A: Post-Stabilization Persistence Models
// additive-only — no existing model modifications
// ════════════════════════════════════════════════════════════════════

// ── Stabilization Baseline ──

model StabilizationBaseline {
  id                          String   @id @default(cuid())
  baselineSource              String   // e.g. "PACKAGE1_COMPLETE_NEW_AI_INTEGRATED"
  baselineVersion             String
  baselineHash                String
  lifecycleState              String   // SHADOW | ACTIVE_5 | ACTIVE_25 | ACTIVE_50 | ACTIVE_100 | KILLED
  releaseMode                 String   // CANARY_ROLLOUT | FULL_ACTIVE_STABILIZATION | POST_STABILIZATION
  baselineStatus              String   // UNFROZEN | FROZEN | INVALIDATED
  activeSnapshotId            String?
  rollbackSnapshotId          String?
  freezeReason                String?  @db.Text
  activePathManifestId        String?
  policySetVersion            String?
  routingRuleVersion          String?
  authorityRegistryVersion    String?
  stabilizationOnly           Boolean  @default(true)
  featureExpansionAllowed     Boolean  @default(false)
  experimentalPathAllowed     Boolean  @default(false)
  structuralRefactorAllowed   Boolean  @default(false)
  devOnlyPathAllowed          Boolean  @default(false)
  emergencyRollbackAllowed    Boolean  @default(true)
  containmentPriorityEnabled  Boolean  @default(true)
  auditStrictMode             Boolean  @default(true)
  mergeGateStrictMode         Boolean  @default(true)
  canonicalSlot               String?  @unique // "CANONICAL" when active; null when invalidated — DB-enforced singleton
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  // relations
  snapshots       StabilizationSnapshot[]
  authorityLines  StabilizationAuthorityLine[]
  incidents       StabilizationIncident[]

  @@index([baselineVersion])
  @@index([lifecycleState])
  @@index([baselineStatus])
  @@index([createdAt])
}

// ── Stabilization Snapshot ──

model StabilizationSnapshot {
  id                        String   @id @default(cuid())
  baselineId                String
  snapshotType              String   // ACTIVE | ROLLBACK
  configChecksum            String?
  flagChecksum              String?
  routingChecksum           String?
  authorityChecksum         String?
  policyChecksum            String?
  queueTopologyChecksum     String?
  includedScopes            Json     // string[] — scope names
  restoreVerificationStatus String?  // PENDING | VERIFIED | FAILED
  scopePayload              Json?    // full scopes array: [{scope, data, checksum}]
  configPayload             Json?    // full config object
  capturedBy                String?  // operator identifier
  snapshotId                String?  @unique // legacy snapshotId for lookup
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // relations
  baseline StabilizationBaseline @relation(fields: [baselineId], references: [id])

  @@index([baselineId])
  @@index([snapshotType])
  @@index([baselineId, snapshotType])
  @@index([createdAt])
}

// ── Stabilization Authority Line ──

model StabilizationAuthorityLine {
  id                  String   @id @default(cuid())
  authorityLineId     String   @unique
  currentAuthorityId  String
  authorityState      String   // ACTIVE | FROZEN | REVOKED | TRANSFERRED
  transferState       String   // IDLE | LOCK_ACQUIRED | PENDING_VALIDATION | FINALIZED | ROLLED_BACK | ESCALATED
  pendingSuccessorId  String?
  revokedAuthorityIds Json     @default("[]") // string[]
  registryVersion     String
  baselineId          String?
  correlationId       String?
  updatedBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // relations
  baseline StabilizationBaseline? @relation(fields: [baselineId], references: [id])

  @@index([currentAuthorityId])
  @@index([authorityState])
  @@index([baselineId])
  @@index([correlationId])
  @@index([createdAt])
}

// ── Stabilization Incident ──

model StabilizationIncident {
  id              String    @id @default(cuid())
  incidentId      String    @unique
  reasonCode      String
  severity        String    // INFO | WARNING | CRITICAL
  status          String    // OPEN | ACKNOWLEDGED | ESCALATED | RESOLVED | CLOSED
  correlationId   String
  baselineId      String?
  snapshotId      String?
  acknowledgedBy  String?
  acknowledgedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // relations
  baseline StabilizationBaseline? @relation(fields: [baselineId], references: [id])

  @@index([incidentId])
  @@index([correlationId])
  @@index([baselineId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

// ── Stabilization Audit Event ──

model StabilizationAuditEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique
  eventType       String   // StabilizationAuditEventType values
  correlationId   String
  incidentId      String?
  baselineId      String?
  snapshotId      String?
  actor           String?
  reasonCode      String?
  severity        String?  // INFO | WARNING | CRITICAL
  sourceModule    String?
  entityType      String?
  entityId        String?
  resultStatus    String?  // ACCEPTED | DENIED | STARTED | COMPLETED | FAILED | ESCALATED
  occurredAt      DateTime
  recordedAt      DateTime @default(now())

  @@index([correlationId])
  @@index([eventType])
  @@index([incidentId])
  @@index([baselineId])
  @@index([occurredAt])
  @@index([recordedAt])
}

// ── Canonical Audit Event ──

model CanonicalAuditEvent {
  id                String   @id @default(cuid())
  eventId           String   @unique
  eventType         String
  eventStage        String?
  correlationId     String
  incidentId        String?
  timelineId        String
  baselineId        String?
  baselineVersion   String?
  baselineHash      String?
  lifecycleState    String?
  releaseMode       String?
  actor             String?
  sourceModule      String
  entityType        String
  entityId          String
  reasonCode        String
  severity          String   // INFO | NOTICE | WARNING | ERROR | CRITICAL
  occurredAt        DateTime
  recordedAt        DateTime @default(now())
  snapshotBeforeId  String?
  snapshotAfterId   String?
  affectedScopes    Json     @default("[]") // string[]
  resultStatus      String   // ACCEPTED | DENIED | STARTED | COMPLETED | FAILED | ESCALATED | QUARANTINED
  parentEventId     String?

  @@index([correlationId])
  @@index([timelineId])
  @@index([eventType])
  @@index([incidentId])
  @@index([baselineId])
  @@index([occurredAt])
  @@index([recordedAt])
  @@index([parentEventId])
}

// ── P1-2: Distributed Lock ──

enum StabilizationLockTarget {
  CANONICAL_BASELINE
  AUTHORITY_LINE
  INCIDENT_STREAM
  SNAPSHOT_RESTORE
}

model StabilizationLock {
  id            String                   @id @default(cuid())
  lockKey       String                   @unique
  lockOwner     String
  lockToken     String
  targetType    StabilizationLockTarget
  reason        String
  correlationId String
  acquiredAt    DateTime                 @default(now())
  expiresAt     DateTime

  @@index([targetType])
  @@index([expiresAt])
}

// ── P2-1: Recovery State Persistence ──

model StabilizationRecoveryRecord {
  id                  String    @id @default(cuid())
  recoveryId          String    @unique
  correlationId       String
  incidentId          String?
  baselineId          String
  lifecycleState      String
  releaseMode         String
  recoveryState       String
  recoveryStage       String?
  lockKey             String?
  lockToken           String?
  operatorId          String
  overrideUsed        Boolean   @default(false)
  overrideReason      String?
  signOffMetadata     Json?
  startedAt           DateTime
  completedAt         DateTime?
  lastHeartbeatAt     DateTime?
  failureReasonCode   String?
  stageResults        Json?
  preconditionResults Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([correlationId])
  @@index([recoveryState])
}

// =====================================================
// 알림 오케스트레이션 (Notification Orchestration)
// =====================================================

// 알림 이벤트 — 비즈니스 이벤트 발생 기록
model NotificationEvent {
  id            String   @id @default(cuid())
  eventType     String   // e.g. "QUOTE_RECEIVED", "ORDER_SHIPPED"
  entityType    String   // e.g. "QUOTE", "ORDER", "INVENTORY"
  entityId      String
  triggeredBy   String?  // userId who triggered, null for system
  metadata      Json?    // extra context
  createdAt     DateTime @default(now())

  actions       NotificationAction[]

  @@index([entityType, entityId])
  @@index([eventType])
  @@index([createdAt])
}

// 알림 액션 — 이벤트에서 파생된 개별 알림/작업
model NotificationAction {
  id             String   @id @default(cuid())
  eventId        String
  event          NotificationEvent @relation(fields: [eventId], references: [id])

  actionType     String   // "IN_APP", "EMAIL_DRAFT", "QUEUE_ITEM", "ESCALATION"
  recipientId    String?  // userId
  recipientEmail String?

  status         String   @default("PENDING") // PENDING, GENERATED, REVIEWED, APPROVED, SENT, READ, FAILED
  payload        Json?    // notification content

  entityType     String   // denormalized for query
  entityId       String   // denormalized for query

  reviewedBy     String?
  reviewedAt     DateTime?
  sentAt         DateTime?
  readAt         DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([recipientId, status])
  @@index([status])
  @@index([entityType, entityId])
}

// ══════════════════════════════════════════════════════
// Governance Persistence — sessionStorage → Server 전환
// ══════════════════════════════════════════════════════

// Approval 시점 PO baseline snapshot (dispatch changedFields diff 계산용)
model ApprovalBaseline {
  id                 String   @id @default(cuid())
  poNumber           String
  approvalDecidedAt  String   // ISO datetime — approval 결정 시각
  capturedAt         String   // ISO datetime — snapshot 저장 시각

  // diff 계산용 최소 필드 집합
  totalAmount        Float
  vendorId           String
  paymentTerms       String?
  incoterms          String?
  shippingRegion     String
  billToEntity       String
  shipToLocation     String
  notes              String?
  lineCount          Int

  invalidatedAt      DateTime?  // targeted invalidation 시 soft-delete
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([poNumber, approvalDecidedAt])
  @@index([poNumber])
}

// Dispatch outbound execution history (schedule/cancel lineage)
model OutboundHistory {
  id         String   @id @default(cuid())
  poId       String
  seqIndex   Int      // history 배열 내 순서 (0-based)

  recordType String   // "schedule" | "cancel" | "cancel_prep"
  payload    Json     // DispatchOutboundRecord 전체 직렬화

  createdAt  DateTime @default(now())

  @@unique([poId, seqIndex])
  @@index([poId])
}

// ── PO Conversion Candidate ──────────────────────────────────────────────
// AI 견적 분석 → PO 전환 후보. MOCK_CANDIDATES 를 대체하는 persistent model.
// order_queue (Supabase) 와는 별도 — 여기는 multi-line items + 선정 사유 + blocker 등
// presentation-enriched 필드를 보관한다.
model POCandidate {
  id               String   @id @default(cuid())
  userId           String
  organizationId   String?

  title            String                     // "Thermo Fisher FBS 외 2건"
  vendor           String
  totalAmount      Int                        // KRW
  expectedDelivery DateTime?
  selectionReason  String?  @db.Text          // AI 선정 사유
  blockers         String[] @default([])      // blocker 문자열 배열
  // §11.209b-pre — String → ApprovalPolicy enum 통일. application code 의
  // string literal "none" / "in_app_approval" / "external_approval" 그대로
  // 호환 (Prisma 가 enum value 와 string literal 자동 매핑).
  approvalPolicy   ApprovalPolicy @default(none)
  // §11.99b — String → POCandidateApprovalStatus enum 통일 (옵션 A —
  // AiActionItem.approvalStatus 의 ApprovalStatus enum 과 분리, 별도 이름).
  approvalStatus   POCandidateApprovalStatus @default(not_required)
  stage            String   @default("po_conversion_candidate") // ProcurementStage (string)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            POCandidateItem[]
  // #post-approval-purchase-order-flow Phase 1.2 — POCandidate → Order 1:1 매핑
  orders           Order[]

  @@index([userId])
  @@index([organizationId])
  @@index([stage])
}

model POCandidateItem {
  id             String @id @default(cuid())
  candidateId    String
  name           String
  catalogNumber  String
  quantity       Int    @default(1)
  unitPrice      Int
  lineTotal      Int
  leadTime       String @default("")

  candidate      POCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

// Step 1 Review Queue Draft (sessionStorage → DB 영속화)
model ReviewQueueDraft {
  id         String   @id @default(cuid())
  userId     String
  payload    Json     // ReviewQueueItem[] 전체 직렬화

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId])
  @@index([userId])
}

// Governance event publish dedupe (cross-session 중복 방지)
model GovernanceEventDedupe {
  id            String   @id @default(cuid())
  poNumber      String
  eventType     String
  signatureKey  String

  publishedAt   DateTime @default(now())
  expiresAt     DateTime  // TTL 만료 시각

  @@unique([poNumber, eventType, signatureKey])
  @@index([poNumber])
  @@index([expiresAt])
}

// ─── Governance Audit Log (Security Batch 6) ─────────────
// append-only, tamper-evident hash chain audit.
// Security enforcement middleware가 기록하는 irreversible action evidence.
// UPDATE/DELETE 금지 — INSERT + SELECT only.
model GovernanceAuditLog {
  id                    String   @id @default(cuid())
  eventId               String   @unique               // audit_xxxx_xxx 형식
  correlationId         String                          // 요청 단위 추적
  actorUserId           String                          // 행위자 user ID
  actorRole             String                          // 행위자 시스템 역할
  actionType            String                          // irreversible action type
  targetEntityType      String                          // po, quote, dispatch, approval 등
  targetEntityId        String                          // 대상 entity ID
  occurredAt            DateTime                        // 이벤트 발생 시각
  snapshotVersion       String   @default("v0")         // 스냅샷 버전
  beforeHash            String                          // 변경 전 상태 hash
  afterHash             String                          // 변경 후 상태 hash
  rationale             String?  @db.Text               // 결재 사유
  reasonCode            String                          // action reason code
  sourceSurface         String                          // UI surface 출처
  previousEnvelopeHash  String                          // 이전 envelope hash (chain)
  envelopeHash          String   @unique                // 이 envelope 자체 hash
  securityClassification String  @default("audit_evidence") // internal_only, governance_restricted, audit_evidence, supplier_facing
  createdAt             DateTime @default(now())

  @@index([correlationId])
  @@index([actorUserId])
  @@index([actionType])
  @@index([targetEntityType, targetEntityId])
  @@index([envelopeHash])
  @@index([occurredAt])
}

// ────────────────────────────────────────────────────────────
// 카테고리별 지출 통제 (Category-Based Spending Control)
// ────────────────────────────────────────────────────────────

/// 지출 카테고리 (관리자가 추가/수정/삭제 가능)
model SpendingCategory {
  id              String    @id @default(cuid())
  organizationId  String
  name            String    // 내부 키 (org 내 유일)
  displayName     String    // 표시명 (한국어)
  description     String?
  color           String    @default("#6366f1") // tailwind indigo-500
  icon            String?   // lucide icon name (e.g. "Beaker", "Package")
  sortOrder       Int       @default(0)
  isActive        Boolean   @default(true)
  isDefault       Boolean   @default(false) // 시드 카테고리 여부
  archivedAt      DateTime? // null=활성, 값 있으면 아카이브된 시각
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id])
  budgets          CategoryBudget[]
  purchaseRecords  PurchaseRecord[] // normalizedCategoryId FK

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
}

/// 카테고리별 월간 예산 한도
model CategoryBudget {
  id               String    @id @default(cuid())
  organizationId   String
  categoryId       String
  yearMonth        String    // "YYYY-MM"
  amount           Int       // 예산 금액 (KRW)
  currency         String    @default("KRW")
  warningPercent   Int       @default(70)   // 경고 임계치
  softLimitPercent Int       @default(90)   // 소프트 리밋
  hardStopPercent  Int       @default(100)  // 하드 스톱
  controlRules     Json?     // ["warning","soft_limit","hard_stop"] 등
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id])
  category         SpendingCategory @relation(fields: [categoryId], references: [id])

  @@unique([organizationId, categoryId, yearMonth])
  @@index([organizationId, yearMonth])
  @@index([categoryId])
}

// 예산 이벤트 (idempotency + durable audit trail)
// reserve(approve) / release(reverse/cancel/void/reclass) 이벤트를 기록.
// budget_event_key unique 제약으로 동일 이벤트 중복 실행 방지.
model BudgetEvent {
  id                String    @id @default(cuid())
  organizationId    String
  // idempotency key: orgId + sourceEntityId + eventType + sequence
  // 예: "org-1:req-abc:approval_reserved:1"
  budgetEventKey    String    @unique
  eventType         String    // approval_reserved | approval_reversed | request_cancel_released | po_void_released | category_reclass_release_reapply
  sourceEntityType  String    // purchase_request | order
  sourceEntityId    String
  categoryId        String?
  yearMonth         String    // period key의 YYYY-MM 부분
  amount            Int       // 양수: reserve/release, 음수: reapply
  preCommitted      Int       // 이벤트 전 committed
  postCommitted     Int       // 이벤트 후 committed
  // gate decision 전체 (BudgetGateAuditEvent JSON)
  decisionPayload   Json?
  executedBy        String
  executedAt        DateTime  @default(now())

  organization      Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, yearMonth])
  @@index([sourceEntityId])
  @@index([categoryId, yearMonth])
}

// ─── Mutation Audit Event (Batch 6: Durable Audit Sink) ─────────────
// 모든 irreversible mutation의 durable audit trail.
// 같은 DB 트랜잭션 안에서 mutation과 함께 기록 (transactional outbox 패턴).
// append-only — UPDATE/DELETE 금지, INSERT + SELECT only.
// replay/duplicate retry가 들어와도 auditEventKey unique 제약으로 중복 증식 방지.
model MutationAuditEvent {
  id                    String    @id @default(cuid())
  // idempotency key: orgId:route:entityId:action:sequence
  auditEventKey         String    @unique
  occurredAt            DateTime  @default(now())
  orgId                 String
  actorId               String                            // userId or "system"
  route                 String                            // /api/request/[id]/approve 등
  action                String                            // purchase_request_approve, purchase_request_cancel 등
  entityType            String                            // purchase_request, order, purchase_record, invite
  entityId              String
  result                String                            // success, blocked, error
  correlationId         String                            // enforcement correlationId
  // domain-specific context fields (nullable — route에 따라 다름)
  requestId             String?
  orderId               String?
  purchaseRecordId      String?
  periodKey             String?                           // orgId:categoryId:YYYY-MM
  normalizedCategoryId  String?
  amount                Int?
  thresholds            Json?                             // { warningPercent, softLimitPercent, hardStopPercent }
  decisionBasis         Json?                             // BudgetGateDecisionBasis[] or full decision payload
  budgetEventKey        String?                           // 연결된 BudgetEvent의 idempotency key
  compensatingForEventId String?                          // reopen/reverse 시 원본 event 참조
  recordedAt            DateTime  @default(now())

  @@index([orgId, occurredAt])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([action])
  @@index([correlationId])
  @@index([route])
}

// ─── Contact Inquiry (퍼블릭 문의 인입) ─────────────────────────────
// /support 페이지에서 접수된 문의. 로그인 불필요.
// 운영 티켓이 아니라 리드/문의 인입 폼. append-only.
model ContactInquiry {
  id            String   @id @default(cuid())
  referenceId   String   @unique  // 사용자에게 노출되는 참조 번호 (INQ-YYYYMMDD-XXXX)
  inquiryType   String             // service, pricing, sourcing, account
  name          String             // 이름 또는 기관명
  email         String             // 연락 이메일
  message       String   @db.Text  // 문의 내용
  status        String   @default("received")  // received, reviewed, replied, closed
  ipAddress     String?            // 스팸 방지용 (선택적)
  userAgent     String?  @db.Text  // 접속 환경 (선택적)
  createdAt     DateTime @default(now())
  reviewedAt    DateTime?          // 담당자 확인 시각
  repliedAt     DateTime?          // 답변 시각

  @@index([email])
  @@index([inquiryType])
  @@index([status])
  @@index([createdAt])
}

// ─── §11.106 #dashboard-stats-snapshot-table ────────────────────────
// Daily snapshot of dashboard KPIs for trend derivation (point-in-time
// count). §11.94 Phase 1 (week-over-week spending) 후속 backend source —
// store-derived KPIs (pendingApproval / anomaly / processingRequired) 의
// trend chip 활성화 가능.
//
// Capture: Vercel cron (`/api/cron/dashboard-snapshot`) daily — 또는
// admin manual trigger.
//
// Trend derive: `/api/dashboard/stats` 가 응답에 어제/1주 전 snapshot
// 비교 metric 추가. 데이터 누적 후 자동 활성.
model DashboardStatsSnapshot {
  id             String   @id @default(cuid())
  organizationId String?  // 조직별 분리 (multi-tenant)
  userId         String?  // 개인별 (organization 부재 시)
  capturedAt     DateTime @default(now())

  // 핵심 KPI metrics (향후 trend 산출 source)
  pendingApprovalCount    Int    @default(0) // 진행 중 발주 (status=pending_approval)
  anomalyCount            Int    @default(0) // 이상 신호 (over budget + high value order)
  processingRequiredCount Int    @default(0) // 처리 필요 항목 (lowStock + expiring + undecided)
  totalSpent              BigInt @default(0) // 누적 지출 (KRW)
  totalBudget             BigInt @default(0) // 총 예산 (KRW)

  // capture metadata
  capturedBy String? // userId who triggered (null = cron auto)
  source     String  @default("auto") // "auto" (cron) | "manual" (admin)

  @@index([organizationId, capturedAt])
  @@index([userId, capturedAt])
  @@index([capturedAt])
}

// ─── §11.290 #smart-receiving-ai-ocr ────────────────────────────────
// Multi-provider OCR fallback (Gemini primary + Cloud Vision OCR +
// Claude 구조화 secondary + regex tertiary) 의 audit / cache / 재처리
// root. 호영님 P1 spec (2026-05-23).
//
// Phase 1 = schema 정합만. Phase 2~4 에서 image-storage helper +
// orchestrator + UI wiring + 4 route 작성. Phase 5 에서 Vercel env
// (GOOGLE_VISION_API_KEY + ANTHROPIC_API_KEY) 설정 + smoke + ADR.
//
// Wiring 결정 (호영님 2026-05-23):
//   기존 3 route (/api/inventory/scan-label, /api/quotes/parse-image,
//   /api/quotes/parse-pdf) 내부만 orchestrator 호출로 swap. 새 route
//   는 재처리 / 수동 보정 surface 만 신설 (/api/ocr/retry/[jobId],
//   /api/ocr/correct/[jobId]).
//
// OcrJob = 1번 OCR scan request. imageHash 로 캐시 lookup (TTL 48h).
// OcrResult = provider 별 호출 결과 (1:N) — cross-validation 위함.
// finalResult = 최종 채택된 결과 (canonical winner, 사용자 confirm 전).
enum OcrJobType {
  LABEL  // 시약 라벨
  QUOTE  // 견적서 / 거래명세서
}

enum OcrJobStatus {
  PENDING       // 생성 직후
  RUNNING       // provider 호출 중
  SUCCESS       // confidence ≥ 0.85, auto prefill 가능
  FAILED        // 모든 provider 실패
  NEEDS_REVIEW  // confidence < 0.7, 수동 보정 필요
}

enum OcrProvider {
  GEMINI                // 1차: Gemini 2.5 Flash multimodal
  CLOUD_VISION_CLAUDE   // 2차: Cloud Vision OCR + Claude 구조화
  REGEX                 // 3차: label-parser.ts regex/heuristic fallback
}

model OcrJob {
  id             String       @id @default(cuid())
  organizationId String       // tenant 분리
  userId         String       // scan 실행자
  type           OcrJobType
  imageUrl       String       // Vercel Blob URL (영구 저장)
  imageHash      String       // SHA-256(imageBase64) — cache lookup key
  status         OcrJobStatus @default(PENDING)
  results        OcrResult[]  @relation("OcrJobResults")
  finalResult    OcrResult?   @relation("OcrJobFinal", fields: [finalResultId], references: [id])
  finalResultId  String?      @unique
  // §11.290 Phase 6.b — cache hit audit back-relation (정확 cacheHitRatio metric)
  cacheHits      OcrCacheHit[]
  // §11.309a — 스마트 입고 back-relation. 한 OCR job 으로 여러 receiving 생성
  // 가능 (예: 거래명세서 다수 품목 일괄 입고).
  restocks       InventoryRestock[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, type])
  @@index([imageHash])  // cache lookup O(log n)
}

// §11.290 Phase 6.b — 정확 cache hit count audit.
// Phase 5.5 의 findCachedOcrJob cache hit branch 에서 INSERT.
// Phase 6 의 cacheReuseRatio proxy ((totalJobs - uniqueHashes) / totalJobs) →
// 정확 cacheHitRatio = cacheHitCount / (totalJobs + cacheHitCount) 로 swap.
model OcrCacheHit {
  id             String   @id @default(cuid())
  cachedJob      OcrJob   @relation(fields: [cachedJobId], references: [id], onDelete: Cascade)
  cachedJobId    String   // cache hit 의 source OcrJob.id
  organizationId String   // tenant 분리 (multi-tenant aggregation)
  userId         String   // cache hit 트리거한 사용자
  imageHash      String   // SHA-256 (audit / debug)
  hitAt          DateTime @default(now())

  @@index([organizationId, hitAt])
  @@index([cachedJobId])
}

model OcrResult {
  id             String      @id @default(cuid())
  jobId          String
  job            OcrJob      @relation("OcrJobResults", fields: [jobId], references: [id], onDelete: Cascade)
  provider       OcrProvider
  parsedFields   Json        // LabelParseResult | ParsedQuoteDocument shape
  confidence     Float       // 0.0 ~ 1.0
  rawText        String?     @db.Text // OCR raw text (regex caller 검증용)
  costUsd        Float       // per-call cost (e.g. 0.001 Gemini, 0.0015 Vision, 0.03 Claude)
  latencyMs      Int         // call latency for monitoring
  errorMessage   String?     @db.Text // fallback chain audit
  createdAt      DateTime    @default(now())
  finalForJob    OcrJob?     @relation("OcrJobFinal")  // back-relation for finalResult

  @@index([jobId])
}


// =====================================================
// §11.348-A — 발주→회신→입고 폐루프 (검증 대기 입고안)
// =====================================================
// A-3 본체: 공급사가 발주(PO) 후 회신한 입고 정보(LOT·납기·실수량)를
// "검증 대기 입고안"으로 보관한다. canonical 아님(derived 제안).
// 승인 전 재고·LOT mutation 0 (§11.336). 사람 승인(A-4)에서만
// InventoryRestock(delivery-sync) 생성 → canonical 승격. ReceivingDraft 는
// 어떤 ProductInventory 도 변경하지 않는다(순수 데이터). token = 공급사
// 회신 링크(A-1). orderItemId/productId 는 scalar(OrderItem.productId 선례).

enum ReceivingDraftStatus {
  AWAITING_REPLY // 발주 후 회신 대기 (링크 발송, 미회신)
  PENDING_REVIEW // 공급사 회신 도착 → 사람 검증 대기
  APPROVED       // 승인 → 입고 확정(InventoryRestock 생성됨)
  REJECTED       // 반려
  EXPIRED        // 링크 만료
}

model ReceivingDraft {
  id              String               @id @default(cuid())
  orderId         String               // FK to Order(PO)
  userId          String               // 발주 주체/감사 소유자
  organizationId  String?              // 조직 스코프
  vendorId        String?              // 회신한 공급사
  token           String               @unique // 공급사 회신 링크 공개 토큰 (A-1)
  status          ReceivingDraftStatus @default(AWAITING_REPLY)
  submittedAt     DateTime?            // 공급사 회신 제출 시각
  reviewedAt      DateTime?            // 사람 검증(승인/반려) 시각
  approvedById    String?              // 승인자 (audit, scalar)
  rejectedReason  String?              @db.Text
  vendorNote      String?              @db.Text // 공급사 회신 메모
  snapshot        Json?                // 발송 시점 PO 스냅샷 (회신 폼 freeze)
  expiresAt       DateTime             // 링크 만료
  restockSyncedAt DateTime?            // InventoryRestock 생성 완료 시각 (이중 입고 idempotent 가드)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  order        Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  vendor       Vendor?              @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  items        ReceivingDraftItem[]

  @@index([orderId])
  @@index([userId])
  @@index([organizationId])
  @@index([vendorId])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

// 검증 대기 입고안 품목 (공급사 회신 품목별). 순수 데이터, 재고 미변경.
model ReceivingDraftItem {
  id               String    @id @default(cuid())
  receivingDraftId String
  orderItemId      String?   // PO 품목 매핑 (scalar — OrderItem.productId 선례)
  productId        String?   // 제품 매핑 (승인 시 InventoryRestock 대상)
  name             String    // 품목명 (스냅샷)
  expectedQuantity Float?    // PO 발주 수량
  receivedQuantity Float?    // 공급사 회신 실수량
  unit             String?
  lotNumber        String?   // 회신 LOT
  expiryDate       DateTime? // 회신 유효기간
  vendorNote       String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  receivingDraft ReceivingDraft @relation(fields: [receivingDraftId], references: [id], onDelete: Cascade)

  @@index([receivingDraftId])
  @@index([orderItemId])
  @@index([productId])
}


// =====================================================
// §11.348-B-1 — SDS/MSDS 문서 (파일 스토리지 메타 + 추출 결과)
// =====================================================
// 파일 원본은 오브젝트 스토리지(bucket/path), DB엔 메타+링크만(BLOB 금지).
// 기존 라우트(api/sds/[id]/{signed-url,extract,apply}, api/products/[id]/sds,
// api/safety/sds, admin/safety)가 참조하던 db.sDSDocument 모델을 정규화.
// 추출 결과(extractionResult)는 검증 전 derived — canonical 안전필드(Product)
// 승격은 사람 승인(api/sds/[id]/apply). source: upload(직접) / ocr / vendor.

model SDSDocument {
  id               String    @id @default(cuid())
  productId        String
  organizationId   String?   // 공용 문서 = null
  // §detail-page P2 — COA(lot-scoped) 경계. coa=>NOT NULL, sds=>NULL. CHECK constraint `SDSDocument_coa_lot_check` 강제.
  inventoryId      String?
  // #inventory-lot-entity P3 — COA(lot-scoped) 를 실 입고 lot(InventoryRestock) 에 바인딩. coa=>restockId NOT NULL, sds=>NULL. CHECK `SDSDocument_coa_lot_check` 재정의.
  restockId        String?
  fileName         String
  bucket           String    // 오브젝트 스토리지 버킷(Supabase/Blob)
  path             String    // 스토리지 경로
  source           String    @default("upload") // upload / ocr / vendor
  // §11.348-B-1 B1-4 — 문서 종류 판별자(sds/coa). 기존 행 backward-compat = "sds".
  // ⚠️ docType 값 추가(예: msds/spec) 시 SDSDocument_coa_lot_check CHECK constraint 동반 갱신 필수 — 미갱신 시 신규 docType INSERT 전면 차단.
  docType          String    @default("sds") // sds / coa
  contentType      String?
  sizeBytes        Int?
  extractionStatus String?   // queued / processing / done / failed (null=미추출)
  extractionResult Json?     // 추출된 안전 필드(검증 전 derived 제안)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  inventory    ProductInventory? @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  restock      InventoryRestock? @relation(fields: [restockId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([organizationId])
  @@index([inventoryId])
  @@index([restockId])
  @@index([extractionStatus])
  @@index([docType])
}
