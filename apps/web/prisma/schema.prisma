// 입고 상태
enum ReceivingStatus {
  PENDING   // 대기
  PARTIAL   // 일부입고
  COMPLETED // 완료
  ISSUE     // 이슈
}

// 재고 입고 이력
model InventoryRestock {
  id               String          @id @default(cuid())
  inventoryId      String
  userId           String
  quantity         Float           // 입고 수량
  expectedQuantity Float?          // 예상 입고 수량
  unit             String?         // 단위
  lotNumber        String?         // Lot 번호
  expiryDate       DateTime?       // 유효기간
  receivingStatus  ReceivingStatus @default(COMPLETED) // P7-1: 입고 상태
  orderId          String?         // P7-1: 연결된 주문
  issueNote        String?         @db.Text // P7-1: 이슈 사유
  notes            String?         @db.Text
  restockedAt      DateTime        @default(now())
  createdAt        DateTime        @default(now())

  // §11.309a — 스마트 입고 OCR 스캔 연결 (호영님 P0 2026-05-26).
  // ocrJobId null = 수동 입고, ocrJobId 있음 = OCR 스캔으로 등록된 입고.
  // extractedData 는 사용자가 확인/수정한 최종 데이터 (감사 추적용).
  ocrJobId         String?
  extractedData    Json?           // 확인된 OCR 추출 데이터 (감사 추적)

  // 관계
  inventory ProductInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  // §11.309a — OcrJob FK. SetNull 으로 OcrJob 삭제 시에도 InventoryRestock 보존.
  ocrJob    OcrJob?          @relation(fields: [ocrJobId], references: [id], onDelete: SetNull)
  // #inventory-lot-entity P3 — lot-scoped COA 역방향.
  sdsDocuments SDSDocument[]

  @@index([inventoryId])
  @@index([userId])
  @@index([restockedAt])
  @@index([orderId])
  @@index([receivingStatus])
  @@index([ocrJobId])  // §11.309a — 스캔 입고 조회 O(log n)
}

// 점검 결과
enum InspectionResult {
  PASS      // 양호
  CAUTION   // 주의
  FAIL      // 불량
}

// 재고 점검 기록
model Inspection {
  id              String           @id @default(cuid())
  inventoryId     String
  userId          String
  organizationId  String?
  result          InspectionResult
  checklist       Json             // { storageOk, labelOk, expiryOk, conditionOk }
  notes           String?          @db.Text
