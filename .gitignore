# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — 실제 값(.env / .env.local 등)은 절대 커밋 금지.
#   예시 파일(.env.example, 변수 이름만)은 커밋 허용(팀·Vercel 등록용 체크리스트).
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# 삭제된 파일 (다시 추가 방지)
apps/web/public/brand/bioinsight-icon.PNG
apps/web/public/brand/bioinsight-icon.svg
.mcp.json

# Prisma migrations backup (pre-baseline consolidation)
apps/web/prisma/migrations.backup-*

# Claude Code sandbox artifacts (never commit)
.claude/worktrees/
tmpclaude-*-cwd
*.tsx.bak
*.ts.bak
*.bak

# LabAxis agent review generated reports
.labaxis/runs/*.md
