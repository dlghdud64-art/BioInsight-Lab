{
  "name": "ai-biocompare",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && npm run dev",
    "build": "cd apps/web && npm run build",
    "lint": "cd apps/web && npm run lint",
    "test": "cd apps/web && npm run test",
    "test:watch": "cd apps/web && npm run test:watch",
    "test:ui": "cd apps/web && npm run test:ui",
    "test:coverage": "cd apps/web && npm run test:coverage",
    "db:generate": "cd apps/web && npm run db:generate",
    "db:migrate": "cd apps/web && npm run db:migrate",
    "prisma:migrate": "cd apps/web && npm run prisma:migrate",
    "typecheck": "cd apps/web && npx tsc --noEmit",
    "prepare": "husky || true"
  },
  "dependencies": {
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "recharts": "^3.7.0",
    "tailwindcss": "^3.4.18"
  },
  "devDependencies": {
    "@types/node": "^20.19.26",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
